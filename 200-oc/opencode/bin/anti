#!/bin/bash
set -eo pipefail

case "${1:-}" in
    restart) systemctl --user restart opencode-anti ;;
    start)   systemctl --user start opencode-anti ;;
    stop)    systemctl --user stop opencode-anti ;;
    status)  systemctl --user status opencode-anti ;;
    *)       OPENCODE_SERVER_PASSWORD=opencode exec /home/jclee/.opencode/bin/opencode attach http://127.0.0.1:3001 --dir "$(pwd)" "$@" ;;
esac
