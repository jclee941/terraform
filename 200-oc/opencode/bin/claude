#!/bin/bash
set -eo pipefail

case "${1:-}" in
    restart) systemctl --user restart opencode-claude ;;
    start)   systemctl --user start opencode-claude ;;
    stop)    systemctl --user stop opencode-claude ;;
    status)  systemctl --user status opencode-claude ;;
    *)       OPENCODE_SERVER_PASSWORD=opencode exec /home/jclee/.opencode/bin/opencode attach http://127.0.0.1:3002 --dir "$(pwd)" "$@" ;;
esac
