[Unit]
Description=OpenCode ({{ variant }})
After=network.target

[Service]
Type=simple
Environment=XDG_CONFIG_HOME={{ xdg_config_home }}
Environment=PATH={{ nvm_path }}:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart={{ opencode_bin }} serve --port {{ port }} --hostname 127.0.0.1
WorkingDirectory=%h
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
