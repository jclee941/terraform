    {
      "parameters": {
        "jsCode": "// Resolve current weekly milestone\nconst response = $input.first().json;\nconst milestones = response.body || response;\nconst items = Array.isArray(milestones) ? milestones : [];\n\nfunction getISOWeek(date) {\n  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));\n  const dayNum = d.getUTCDay() || 7;\n  d.setUTCDate(d.getUTCDate() + 4 - dayNum);\n  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));\n  return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);\n}\n\nconst now = new Date();\nconst year = now.getFullYear();\nconst week = getISOWeek(now);\nconst weekStr = String(week).padStart(2, '0');\nconst milestoneTitle = `Week ${year}-W${weekStr}`;\n\nconst found = items.find(m => m.title === milestoneTitle);\nconst prevData = $('Is Create?').first().json;\n\nreturn [{\n  json: {\n    ...prevData,\n    milestoneNumber: found ? found.number : null,\n    milestoneTitle\n  }\n}];"
      },
