      "id": "fetch-github",
      "name": "Fetch GitHub Issues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        690,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Compare GlitchTip issues with GitHub issues\nconst glitchtipResponse = $('Fetch GlitchTip Issues').first().json;\nconst githubResponse = $('Fetch GitHub Issues').first().json;\n\nconst gtIssues = glitchtipResponse.body || glitchtipResponse;\nconst ghIssues = (githubResponse.body || githubResponse) || [];\n\nconst gtList = Array.isArray(gtIssues) ? gtIssues : [];\nconst ghList = Array.isArray(ghIssues) ? ghIssues : [];\n\n// Create fingerprint helper (same as elk-error-pipeline)\nfunction fingerprint(title) {\n  let hash = 0;\n  for (let i = 0; i < title.length; i++) {\n    const char = title.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash |= 0;\n  }\n  return Math.abs(hash).toString(16).padStart(8, '0');\n}\n\n// ISO week number\nfunction getISOWeek(date) {\n  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));\n  const dayNum = d.getUTCDay() || 7;\n  d.setUTCDate(d.getUTCDate() + 4 - dayNum);\n  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));\n  return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);\n}\n\nconst actions = [];\n\nfor (const gt of gtList) {\n  const title = gt.title || gt.metadata?.title || 'Unknown Error';\n  const fp = fingerprint(title);\n  const isResolved = gt.status === 'resolved';\n  const project = gt.project?.name || gt.shortId?.split('-')[0] || 'unknown';\n  const level = gt.level || 'error';\n  const severity = ['fatal', 'critical'].includes(level.toLowerCase()) ? 'critical' :\n                   level.toLowerCase() === 'warning' ? 'warning' : 'error';\n\n  // Find matching GitHub issue by fingerprint in body\n  const matchingGH = ghList.find(gh => {\n    const body = gh.body || '';\n    return body.includes(fp);\n  });\n\n  if (!matchingGH && !isResolved) {\n    // GlitchTip issue exists without GitHub issue \u2192 create\n    actions.push({\n      action: 'create',\n      fingerprint: fp,\n      title: `[${severity.toUpperCase()}] ${title}`,\n      body: `## Auto-detected Error (Sync)\\n\\n**Source**: GlitchTip Sync\\n**Project**: ${project}\\n**Level**: ${level}\\n**Times Seen**: ${gt.count || 1}\\n**First Seen**: ${gt.firstSeen || 'unknown'}\\n**Last Seen**: ${gt.lastSeen || 'unknown'}\\n**GlitchTip Link**: ${gt.permalink || ''}\\n\\n---\\n\\n**Fingerprint**: \\`${fp}\\`\\n\\n> This issue was automatically created by GlitchTip Sync workflow.`,\n      labels: ['bug', 'glitchtip', 'automated', severity, project],\n      severity,\n      project,\n      glitchtipId: gt.id\n    });\n  } else if (matchingGH && isResolved && matchingGH.state === 'open') {\n    // GlitchTip resolved but GitHub still open \u2192 close\n    actions.push({\n      action: 'close',\n      issueNumber: matchingGH.number,\n      fingerprint: fp,\n      title: matchingGH.title,\n      glitchtipId: gt.id\n    });\n  }\n}\n\nif (actions.length === 0) {\n  return [{ json: { action: 'none', message: 'No sync actions needed' } }];\n}\n\nreturn actions.map(a => ({ json: a }));"
      },
