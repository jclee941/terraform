{
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "set_priority": {
            "priority": 100
          }
        }
      },
      "delete": {
        "min_age": "${ilm_delete_after}",
        "actions": {
          "delete": {}
        }
      }
    }
  }
}
