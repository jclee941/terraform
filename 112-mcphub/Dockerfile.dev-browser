FROM node:22-slim

WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl git && rm -rf /var/lib/apt/lists/*
RUN npm install -g mcp-proxy@6.4.0

# Clone and build dev-browser-mcp
RUN git clone https://github.com/benkraus/dev-browser-mcp.git /app/dev-browser-mcp
WORKDIR /app/dev-browser-mcp
RUN npm install && npm run build

# CDP relay on internal port; mcp-proxy uses 8057 for SSE
ENV HOST=0.0.0.0
ENV PORT=8157
ENV RELAY_MODE=auto

EXPOSE 8057

# Run via mcp-proxy for SSE transport
CMD ["mcp-proxy", "--port", "8057", "--host", "0.0.0.0", "--", "node", "dist/index.js"]
