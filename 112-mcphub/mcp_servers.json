{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "MCP Server Catalog — Single Source of Truth for all MCP server definitions. Consumed by: Terraform (mcp_settings.json rendering), OpenCode gen pipeline (config.py), validation scripts.",
  "mcp_host": "192.168.50.112",
  "mcp_timeout": 60000,
  "servers": {
    "git": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@mseep/git-mcp-server"],
      "port": 8059,
      "description": "Git repository operations"
    },
    "github": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "port": 8058,
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "GitHub API operations"
    },
    "kratos": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "kratos-mcp"],
      "port": 8060,
      "description": "Ory Kratos identity management"
    },
    "proxmox": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-proxmox",
      "port": 8055,
      "description": "Proxmox VE hypervisor management"
    },
    "playwright": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-playwright",
      "port": 8056,
      "description": "Browser automation via Playwright"
    },
    "terraform": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "terraform-mcp-server"],
      "port": 8071,
      "description": "Terraform plan and state inspection"
    },
    "archon": {
      "location": "hub",
      "transport": "streamable-http",
      "url": "http://192.168.50.108:8051/mcp",
      "port": 8078,
      "description": "Archon AI knowledge management"
    },
    "elk": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@awesome-ai/elasticsearch-mcp"],
      "port": 8065,
      "env": {
        "ES_HOST": "${ES_HOST}",
        "ES_USERNAME": "${ES_USERNAME}",
        "ES_PASSWORD": "${ES_PASSWORD}"
      },
      "description": "Elasticsearch query and management"
    },
    "slack": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "slack-mcp-server@latest", "--transport", "stdio"],
      "port": 8079,
      "env": {
        "SLACK_MCP_XOXP_TOKEN": "${SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXB_TOKEN": "${SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_USERS_CACHE": "/tmp/slack-users-cache.json",
        "SLACK_MCP_CHANNELS_CACHE": "/tmp/slack-channels-cache.json"
      },
      "description": "Slack workspace operations"
    },
    "onepassword": {
      "location": "hub",
      "transport": "stdio",
      "command": "node",
      "args": ["/app/op-mcp-server/index.mjs"],
      "port": 8077,
      "env": {
        "OP_SERVICE_ACCOUNT_TOKEN": "${OP_SERVICE_ACCOUNT_TOKEN}"
      },
      "description": "1Password vault and secret management"
    },
    "gcloud": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"],
      "port": 8080,
      "description": "Google Cloud Platform CLI operations"
    },
    "n8n": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@leonardsellem/n8n-mcp-server"],
      "port": 8081,
      "env": {
        "N8N_API_URL": "${N8N_MCP_API_URL}",
        "N8N_API_KEY": "${N8N_MCP_API_KEY}"
      },
      "description": "n8n workflow automation"
}
,
    "gmail-creator": {
      "location": "hub",
      "transport": "stdio",
      "command": "node",
      "args": ["/home/jclee/dev/gmail/gmail-creator-mcp.mjs"],
      "port": 8082,
      "env": {
        "FIVESIM_API_KEY": "${FIVESIM_API_KEY}",
        "SMS_PROVIDER": "${SMS_PROVIDER}",
        "FIVESIM_REGION": "${FIVESIM_REGION}",
        "PROXY_SERVER": "${PROXY_SERVER}",
        "PROXY_USER": "${PROXY_USER}",
        "PROXY_PASS": "${PROXY_PASS}"
      },
      "description": "Google account creation automation"
    }
  }
}
