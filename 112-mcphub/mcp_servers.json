{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "MCP Server Catalog — Single Source of Truth for all MCP server definitions. Consumed by: Terraform (mcp_settings.json rendering), OpenCode gen pipeline (config.py), validation scripts.",
  "mcp_host": "192.168.50.112",
  "mcp_timeout": 60000,
  "servers": {
    "git": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@mseep/git-mcp-server"],
      "port": 8059,
      "description": "Git repository operations"
    },
    "github": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "port": 8058,
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "GitHub API operations"
    },
    "glitchtip": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-glitchtip"],
      "port": 8075,
      "env": {
        "GLITCHTIP_TOKEN": "${GLITCHTIP_TOKEN}",
        "GLITCHTIP_ORGANIZATION": "${GLITCHTIP_ORGANIZATION}",
        "GLITCHTIP_BASE_URL": "${GLITCHTIP_BASE_URL}"
      },
      "description": "GlitchTip error tracking"
    },
    "kratos": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "kratos-mcp"],
      "port": 8060,
      "description": "Ory Kratos identity management"
    },
    "proxmox": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-proxmox",
      "port": 8055,
      "description": "Proxmox VE hypervisor management"
    },
    "playwright": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-playwright",
      "port": 8056,
      "description": "Browser automation via Playwright"
    },
    "supabase": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase"],
      "port": 8076,
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      },
      "description": "Supabase database and API management"
    },
    "terraform": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "terraform-mcp-server"],
      "port": 8071,
      "description": "Terraform plan and state inspection"
    },
    "archon": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://192.168.50.108:8051/mcp",
        "--allow-http",
        "--transport",
        "http-only"
      ],
      "port": 8078,
      "description": "Archon AI knowledge management"
    },
    "elk": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@awesome-ai/elasticsearch-mcp"],
      "port": 8065,
      "env": {
        "ES_HOST": "${ES_HOST}",
        "ES_USERNAME": "${ES_USERNAME}",
        "ES_PASSWORD": "${ES_PASSWORD}"
      },
      "description": "Elasticsearch query and management"
    },
    "slack": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "slack-mcp-server@latest", "--transport", "stdio"],
      "port": 8079,
      "env": {
        "SLACK_MCP_XOXP_TOKEN": "${SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXB_TOKEN": "${SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_USERS_CACHE": "/tmp/slack-users-cache.json",
        "SLACK_MCP_CHANNELS_CACHE": "/tmp/slack-channels-cache.json"
      },
      "description": "Slack workspace operations"
    },
    "onepassword": {
      "location": "hub",
      "transport": "stdio",
      "command": "node",
      "args": ["/app/op-mcp-server/index.mjs"],
      "port": 8077,
      "env": {
        "OP_SERVICE_ACCOUNT_TOKEN": "${OP_SERVICE_ACCOUNT_TOKEN}"
      },
      "description": "1Password vault and secret management"
    }
  }
}
