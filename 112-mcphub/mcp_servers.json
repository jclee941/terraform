{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "MCP Server Catalog — Single Source of Truth for all MCP server definitions. Consumed by: Terraform (mcp_settings.json rendering), OpenCode gen pipeline (config.py), validation scripts.",
  "mcp_host": "192.168.50.112",
  "mcp_timeout": 60000,
  "servers": {
    "git": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@mseep/git-mcp-server"],
      "port": 8059,
      "description": "Git repository operations"
    },
    "kratos": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "kratos-mcp"],
      "port": 8060,
      "description": "Ory Kratos identity management"
    },
    "proxmox": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-proxmox",
      "port": 8055,
      "description": "Proxmox VE hypervisor management",
      "disabled_tools": [
        "proxmox_acme_cert",
        "proxmox_acme_account",
        "proxmox_acme_info",
        "proxmox_ceph",
        "proxmox_ceph_osd",
        "proxmox_ceph_mon",
        "proxmox_ceph_mds",
        "proxmox_ceph_pool",
        "proxmox_ceph_fs",
        "proxmox_sdn_vnet",
        "proxmox_sdn_zone",
        "proxmox_sdn_controller",
        "proxmox_sdn_subnet",
        "proxmox_ha_resource",
        "proxmox_ha_group",
        "proxmox_cluster_firewall",
        "proxmox_cluster_firewall_rule",
        "proxmox_cluster_firewall_group",
        "proxmox_cluster_firewall_alias",
        "proxmox_cluster_firewall_ipset",
        "proxmox_cluster_firewall_ipset_entry",
        "proxmox_guest_firewall_rule",
        "proxmox_cluster_replication_job",
        "proxmox_cluster_config",
        "proxmox_cluster_backup_job",
        "proxmox_console_vnc",
        "proxmox_console_term",
        "proxmox_console_spice",
        "proxmox_user",
        "proxmox_user_token",
        "proxmox_group",
        "proxmox_role",
        "proxmox_acl",
        "proxmox_domain",
        "proxmox_pool",
        "proxmox_guest_delete",
        "proxmox_guest_clone",
        "proxmox_guest_template",
        "proxmox_guest_pause",
        "proxmox_guest_resume",
        "proxmox_guest_disk_move",
        "proxmox_node_disk_admin",
        "proxmox_node_bulk",
        "proxmox_node_power",
        "proxmox_node_replication",
        "proxmox_node_subscription",
        "proxmox_apt",
        "proxmox_notification",
        "proxmox_certificate",
        "proxmox_cloudinit",
        "proxmox_file_restore",
        "proxmox_vm_disk",
        "proxmox_lxc_mountpoint",
        "proxmox_agent_freeze",
        "proxmox_agent_power",
        "proxmox_agent_user",
        "proxmox_agent_hw"
      ]
    },
    "playwright": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-playwright",
      "port": 8056,
      "description": "Browser automation via Playwright"
    },
    "terraform": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "terraform-mcp-server"],
      "port": 8071,
      "description": "Terraform plan and state inspection"
    },
    "archon": {
      "location": "hub",
      "transport": "streamable-http",
      "url": "http://192.168.50.108:8051/mcp",
      "port": 8078,
      "description": "Archon AI knowledge management"
    },
    "elk": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@awesome-ai/elasticsearch-mcp"],
      "port": 8065,
      "env": {
        "ES_HOST": "${ES_HOST}",
        "ES_USERNAME": "${ES_USERNAME}",
        "ES_PASSWORD": "${ES_PASSWORD}"
      },
      "description": "Elasticsearch query and management"
    },
    "onepassword": {
      "location": "hub",
      "transport": "stdio",
      "command": "node",
      "args": ["/app/op-mcp-server/index.mjs"],
      "port": 8077,
      "env": {
        "OP_SERVICE_ACCOUNT_TOKEN": "${OP_SERVICE_ACCOUNT_TOKEN}"
      },
      "description": "1Password vault and secret management"
    },
    "n8n": {
      "location": "hub",
      "transport": "streamable-http",
      "url": "https://n8n.jclee.me/mcp-server/http",
      "port": 8081,
      "disabled": true,
      "description": "n8n workflow automation via native MCP server"
    },
    "supabase": {
      "location": "hub",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase"],
      "port": 8066,
      "disabled": true,
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      },
      "description": "Supabase Cloud Management API (disabled: self-hosted has no Management API v1)"
    },
    "dev-browser": {
      "location": "hub",
      "transport": "sse",
      "docker_service": "mcp-dev-browser",
      "port": 8057,
      "description": "Browser automation with persistent page state"
    }
  }
}
