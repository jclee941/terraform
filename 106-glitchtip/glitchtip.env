# Non-secret configuration for GlitchTip
# Secrets (DJANGO_SECRET_KEY, DATABASE_URL, REDIS_URL) are injected
# via docker-compose.yml environment section from .env (gitignored).
PORT=8000
EMAIL_URL=smtp://localhost:25
DEFAULT_FROM_EMAIL=glitchtip@jclee.me
GLITCHTIP_DOMAIN=https://glitchtip.jclee.me
ENABLE_USER_REGISTRATION=false
