# GitOps controller environment
# Rendered by Terraform - DO NOT EDIT MANUALLY

GITOPS_GITHUB_TOKEN=${github_personal_access_token}
GITOPS_GITHUB_OWNER=${github_org}
GITOPS_GITHUB_REPO=terraform
GITOPS_GITHUB_WORKFLOW=gitops-reconcile.yml
GITOPS_REPO_URL=https://github.com/${github_org}/terraform.git
GITOPS_BRANCH=master
GITOPS_POLL_INTERVAL=15m
GITOPS_REPO_DIR=/var/lib/gitops-agent/repo
GITOPS_STATE_DIR=/var/lib/gitops-agent/state
