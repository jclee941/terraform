{{ with secret "secret/homelab/archon" }}
OPENAI_API_KEY={{ .Data.data.openai_api_key }}
{{ end }}
{{ with secret "secret/homelab/supabase" }}
SUPABASE_URL={{ .Data.data.url }}
SUPABASE_ANON_KEY={{ .Data.data.anon_key }}
{{ end }}
ARCHON_PORT=8181
ARCHON_HOST=0.0.0.0
ARCHON_REASONING_MODEL=o3-mini
ARCHON_PRIMARY_MODEL=gpt-4o
ARCHON_TOOL_MODEL=gpt-4o-mini
ARCHON_MCP_PORT=8051
ARCHON_A2A_PORT=8052
ARCHON_STREAMLIT_PORT=3737
ARCHON_EMBEDDING_MODEL=text-embedding-3-small
ARCHON_EMBEDDING_DIMENSIONS=512
ARCHON_CHUNK_SIZE=2000
ARCHON_CHUNK_OVERLAP=200
ARCHON_CRAWL4AI_PORT=8053
USE_REASONER=true
