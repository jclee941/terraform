services:
  archon-server:
    build:
      context: ./python
      dockerfile: Dockerfile.server
    container_name: archon-server
    ports:
      - "${hosts.archon.ports.server}:${hosts.archon.ports.server}"
    environment:
      - SUPABASE_URL=${supabase_url}
      - SUPABASE_SERVICE_KEY=${supabase_service_role_key}
      - OPENAI_API_KEY=${openai_api_key}
      - SERVICE_DISCOVERY_MODE=docker_compose
      - LOG_LEVEL=INFO
      - ARCHON_SERVER_PORT=${hosts.archon.ports.server}
      - ARCHON_MCP_PORT=${hosts.archon.ports.mcp}
      - ARCHON_UI_PORT=${hosts.archon.ports.ui}
      - ARCHON_HOST=0.0.0.0
    networks:
      - app-network
    command:
      [
        "python",
        "-m",
        "uvicorn",
        "src.server.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "${hosts.archon.ports.server}"
      ]
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:${hosts.archon.ports.server}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped

  archon-mcp:
    build:
      context: ./python
      dockerfile: Dockerfile.mcp
    container_name: archon-mcp
    ports:
      - "${hosts.archon.ports.mcp}:${hosts.archon.ports.mcp}"
    environment:
      - SUPABASE_URL=${supabase_url}
      - SUPABASE_SERVICE_KEY=${supabase_service_role_key}
      - OPENAI_API_KEY=${openai_api_key}
      - TRANSPORT=sse
      - ARCHON_MCP_PORT=${hosts.archon.ports.mcp}
      - ARCHON_SERVER_PORT=${hosts.archon.ports.server}
    networks:
      - app-network
    depends_on:
      archon-server:
        condition: service_healthy
    restart: unless-stopped

  archon-frontend:
    build: ./archon-ui-main
    container_name: archon-ui
    ports:
      - "${hosts.archon.ports.ui}:3737"
    environment:
      - VITE_ARCHON_SERVER_PORT=${hosts.archon.ports.server}
      - ARCHON_SERVER_PORT=${hosts.archon.ports.server}
      - HOST=0.0.0.0
      - PROD=false
      - DOCKER_ENV=true
    networks:
      - app-network
    depends_on:
      archon-server:
        condition: service_healthy
    restart: unless-stopped

networks:
  app-network:
    driver: bridge
