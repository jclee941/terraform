        {
          "index_key": "elk_ilm_policy",
          "schema_version": 0,
          "attributes": {
            "content": "{\n  \"policy\": {\n    \"phases\": {\n      \"hot\": {\n        \"min_age\": \"0ms\",\n        \"actions\": {\n          \"set_priority\": {\n            \"priority\": 100\n          }\n        }\n      },\n      \"delete\": {\n        \"min_age\": \"30d\",\n        \"actions\": {\n          \"delete\": {}\n        }\n      }\n    }\n  }\n}\n",
            "content_base64": null,
            "content_base64sha256": "ttD4D6BB74C3lWgKxcJf+f6sZGqGMQe5kYOYT1VfUos=",
            "content_base64sha512": "10N8NTauMsUEo3OcaFoF6fz/Jg0oq4Y+lXoCVDpxm6EK/p9P/uQb+qXs118TS3GhU2As6Uh+HiK6TBv2xp6qcg==",
            "content_md5": "d677ae404fb0f3eeb25fd41d6cc6ac56",
            "content_sha1": "9bfa2152b2b7ef1064f71fe8e70911fcca371f40",
            "content_sha256": "b6d0f80fa041ef80b795680ac5c25ff9feac646a863107b99183984f555f528b",
            "content_sha512": "d7437c3536ae32c504a3739c685a05e9fcff260d28ab863e957a02543a719ba10afe9f4ffee41bfaa5ecd75f134b71a153602ce9487e1e22ba4c1bf6c69eaa72",
