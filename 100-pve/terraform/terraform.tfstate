    {
      "module": "module.vm_config",
      "mode": "managed",
      "type": "local_file",
      "name": "cloud_init",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": "mcphub",
          "schema_version": 0,
          "attributes": {
            "content": "#cloud-config\nhostname: mcphub\nmanage_etc_hosts: true\n\npackage_update: true\npackage_upgrade: false\n\npackages:\n  - qemu-guest-agent\n  - curl\n  - vim\n  - git\n  - htop\n  - docker.io\n  - docker-compose-v2\n  - sshfs\n  - fail2ban\n\nwrite_files:\n  - path: /opt/mcphub/docker-compose.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      services:\n        mcphub:\n          image: samanhappy/mcphub:0.12.6\n          container_name: mcphub\n          restart: unless-stopped\n          ports:\n            - \"3000:3000\"\n          volumes:\n            - ./mcp_settings.json:/app/mcp_settings.json\n            - mcphub_data:/app/data\n            - npm_cache:/root/.npm\n            - /usr/bin/op:/usr/bin/op:ro\n            - ./op-mcp-server:/app/op-mcp-server:ro\n            - /mnt/oc-dev:/home/jclee/dev:ro\n            - /mnt/oc-dev/gmail:/home/jclee/dev/gmail\n            - ./.gitconfig:/root/.gitconfig:ro\n            - /mnt/oc-kratos:/root/.kratos\n            - ./slack-users-cache.json:/tmp/slack-users-cache.json\n            - ./patches:/app/patches:ro\n            - /usr/lib/google-cloud-sdk:/usr/lib/google-cloud-sdk:ro\n            - /usr/bin/gcloud:/usr/bin/gcloud:ro\n            - ./gcloud-config:/root/.config/gcloud\n          env_file:\n            - .env\n          environment:\n            - MCPHUB_PORT=3000\n          entrypoint: [\"/bin/sh\", \"/app/patches/entrypoint-patch.sh\"]\n          command: [\"pnpm\", \"start\"]\n          healthcheck:\n            test: [\"CMD-SHELL\", \"curl -sf http://localhost:3000/ || exit 1\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 30s\n          depends_on:\n            - mcp-proxmox\n            - mcp-playwright\n      \n        mcp-proxmox:\n          build:\n            context: .\n            dockerfile: Dockerfile.proxmox\n          container_name: mcp-proxmox\n          restart: unless-stopped\n          ports:\n            - \"8055:8055\"\n          env_file:\n            - .env\n          healthcheck:\n            test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8055,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 15s\n      \n        mcp-playwright:\n          build:\n            context: .\n            dockerfile: Dockerfile.playwright\n          container_name: mcp-playwright\n          restart: unless-stopped\n          ports:\n            - \"8056:8056\"\n          env_file:\n            - .env\n          environment:\n            - PLAYWRIGHT_MCP_HEADLESS=true\n          healthcheck:\n            test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8056,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 15s\n      \n        cadvisor:\n          image: gcr.io/cadvisor/cadvisor:v0.51.0\n          container_name: cadvisor\n          ports:\n            - \"8888:8080\"\n          volumes:\n            - /:/rootfs:ro\n            - /var/run:/var/run:ro\n            - /sys:/sys:ro\n            - /var/lib/docker/:/var/lib/docker:ro\n          deploy:\n            resources:\n              limits:\n                memory: 128M\n                cpus: '0.25'\n          logging:\n            driver: json-file\n            options:\n              max-size: \"10m\"\n              max-file: \"3\"\n          restart: unless-stopped\n      \n      volumes:\n        mcphub_data:\n        npm_cache:\n      \n  - path: /opt/mcphub/mcp_settings.json\n    permissions: '0644'\n    owner: root:root\n    content: |\n      {\"mcpServers\":{\"archon\":{\"type\":\"streamable-http\",\"url\":\"http://192.168.50.108:8051/mcp\"},\"elk\":{\"args\":[\"-y\",\"@awesome-ai/elasticsearch-mcp\"],\"command\":\"npx\",\"env\":{\"ES_HOST\":\"${ES_HOST}\",\"ES_PASSWORD\":\"${ES_PASSWORD}\",\"ES_USERNAME\":\"${ES_USERNAME}\"}},\"gcloud\":{\"args\":[\"-y\",\"@google-cloud/gcloud-mcp\"],\"command\":\"npx\"},\"git\":{\"args\":[\"-y\",\"@mseep/git-mcp-server\"],\"command\":\"npx\"},\"github\":{\"args\":[\"-y\",\"@modelcontextprotocol/server-github\"],\"command\":\"npx\",\"env\":{\"GITHUB_PERSONAL_ACCESS_TOKEN\":\"${GITHUB_PERSONAL_ACCESS_TOKEN}\"}},\"gmail-creator\":{\"args\":[\"/home/jclee/dev/gmail/gmail-creator-mcp.mjs\"],\"command\":\"node\",\"env\":{\"FIVESIM_API_KEY\":\"${FIVESIM_API_KEY}\",\"FIVESIM_REGION\":\"${FIVESIM_REGION}\",\"PROXY_PASS\":\"${PROXY_PASS}\",\"PROXY_SERVER\":\"${PROXY_SERVER}\",\"PROXY_USER\":\"${PROXY_USER}\",\"SMS_PROVIDER\":\"${SMS_PROVIDER}\"}},\"kratos\":{\"args\":[\"-y\",\"kratos-mcp\"],\"command\":\"npx\"},\"n8n\":{\"args\":[\"-y\",\"@leonardsellem/n8n-mcp-server\"],\"command\":\"npx\",\"env\":{\"N8N_API_KEY\":\"${N8N_MCP_API_KEY}\",\"N8N_API_URL\":\"${N8N_MCP_API_URL}\"}},\"onepassword\":{\"args\":[\"/app/op-mcp-server/index.mjs\"],\"command\":\"node\",\"env\":{\"OP_SERVICE_ACCOUNT_TOKEN\":\"${OP_SERVICE_ACCOUNT_TOKEN}\"}},\"playwright\":{\"type\":\"sse\",\"url\":\"http://mcp-playwright:8056/sse\"},\"proxmox\":{\"type\":\"sse\",\"url\":\"http://mcp-proxmox:8055/sse\"},\"slack\":{\"args\":[\"-y\",\"slack-mcp-server@latest\",\"--transport\",\"stdio\"],\"command\":\"npx\",\"env\":{\"SLACK_MCP_ADD_MESSAGE_TOOL\":\"true\",\"SLACK_MCP_CHANNELS_CACHE\":\"/tmp/slack-channels-cache.json\",\"SLACK_MCP_USERS_CACHE\":\"/tmp/slack-users-cache.json\",\"SLACK_MCP_XOXB_TOKEN\":\"${SLACK_MCP_XOXB_TOKEN}\",\"SLACK_MCP_XOXP_TOKEN\":\"${SLACK_MCP_XOXP_TOKEN}\"}},\"terraform\":{\"args\":[\"-y\",\"terraform-mcp-server\"],\"command\":\"npx\"}}}\n      \n  - path: /opt/mcphub/Dockerfile.proxmox\n    permissions: '0644'\n    owner: root:root\n    content: |\n      FROM node:22-slim\n      \n      WORKDIR /app\n      RUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends curl \u0026\u0026 rm -rf /var/lib/apt/lists/*\n      RUN npm install -g mcp-proxy@6.4.0\n      RUN npm install --save @bldg-7/proxmox-mcp@latest pino-pretty@latest\n      \n      EXPOSE 8055\n      CMD [\"mcp-proxy\", \"--port\", \"8055\", \"--host\", \"0.0.0.0\", \"--\", \"node\", \"node_modules/@bldg-7/proxmox-mcp/dist/index.js\"]\n      \n  - path: /opt/mcphub/Dockerfile.playwright\n    permissions: '0644'\n    owner: root:root\n    content: |\n      FROM node:22-slim\n      \n      WORKDIR /app\n      RUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends curl \u0026\u0026 rm -rf /var/lib/apt/lists/*\n      RUN npm install -g mcp-proxy@6.4.0\n      RUN npm install --save @playwright/mcp@latest\n      \n      RUN npx playwright install --with-deps chromium chrome\n      \n      ENV PLAYWRIGHT_MCP_HEADLESS=true\n      EXPOSE 8056\n      CMD [\"mcp-proxy\", \"--port\", \"8056\", \"--host\", \"0.0.0.0\", \"--\", \"npx\", \"@playwright/mcp\", \"--no-sandbox\"]\n      \n  - path: /opt/mcphub/.env\n    permissions: '0600'\n    owner: root:root\n    content: |\n      MCPHUB_ADMIN_PASSWORD=c}Tq{lm\u003c]Eu\u003evi)4r={lyaxo\n      N8N_MCP_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkZDFhZDdhMS01ODA5LTRkNTYtYWU2Zi02MmRlNGRkNjc3MjMiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwianRpIjoiODhjNDJiOWUtNThjOC00NGJmLTk2ZDQtZGJmZmZiNGRhYTg2IiwiaWF0IjoxNzcwNzEwNTYzLCJleHAiOjE3Nzg0NzIwMDB9.nSdSyLnxtIk7QaHIVGz6xZB_-ZqBFeXcCzl92KIfRu4\n      N8N_MCP_API_URL=http://192.168.50.110:5678/api/v1\n      OP_SERVICE_ACCOUNT_TOKEN=ops_\n      GITHUB_PERSONAL_ACCESS_TOKEN=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\n      SUPABASE_ACCESS_TOKEN=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogInNlcnZpY2Vfcm9sZSIsICJpc3MiOiAic3VwYWJhc2UiLCAiaWF0IjogMTc3MTYwMDgwMCwgImV4cCI6IDIwODY5NjA4MDB9.vLTEQu-8UATji7axVljZzlmPUrbqbFmx7fjXaQc580Y\n      ES_HOST=http://192.168.50.105:9200\n      ES_USERNAME=elastic\n      ES_PASSWORD=I93bmZ/uT3haNpdL9GJ+neTf\n      PROXMOX_HOST=192.168.50.100\n      PROXMOX_PORT=8006\n      PROXMOX_SSL_MODE=insecure\n      PROXMOX_USER=root@pam\n      PROXMOX_TOKEN_NAME=ci\n      PROXMOX_TOKEN_VALUE=5c12515e-f63d-4c1e-9573-cc0faf729766\n      PROXMOX_ALLOW_ELEVATED=true\n      SLACK_MCP_XOXP_TOKEN=xoxe.xoxp-1-Mi0yLTk5MDY2MjUzMzM1NzQtOTg5MzIyMTEyNzYwNy05OTA4OTkxMzQ0OTQ2LTEwNTk4NzQxMzgxMjY5LWU3MGUzOGM1Y2VlYzQ2MDg3NDU4OWExOTdiNjdiNGY0YWI1YjI1ZmM4OWJkYWNkMDk4M2QwYTkwZDhmN2U3YTg\n      SLACK_MCP_XOXB_TOKEN=xoxb-9906625333574-10531905908103-r6DstzjigyzaE3UMe4yTmbPo\n      \n  - path: /etc/filebeat/filebeat.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      # Filebeat configuration for 112-mcphub (MCP Hub + AI/Tools VM)\n      # Rendered by Terraform - DO NOT EDIT MANUALLY\n      \n      filebeat.autodiscover:\n        providers:\n          - type: docker\n            hints.enabled: true\n      \n      filebeat.inputs:\n        # Docker container logs (mcphub, mcp-proxmox, mcp-playwright, n8n, vault)\n        - type: filestream\n          id: docker-containers\n          paths:\n            - /var/lib/docker/containers/*/*.log\n          parsers:\n            - container: {}\n          prospector.scanner.symlinks: true\n          fields:\n            service: mcphub\n            host_role: mcphub\n          fields_under_root: false\n      \n        # System logs\n        - type: filestream\n          id: system-logs\n          paths:\n            - /var/log/*.log\n            - /var/log/syslog\n          fields:\n            service: system\n            host_role: mcphub\n          fields_under_root: false\n      \n        # Auth logs\n        - type: filestream\n          id: auth-logs\n          paths:\n            - /var/log/auth.log\n          fields:\n            service: auth\n            host_role: mcphub\n          fields_under_root: false\n      \n      processors:\n        - add_host_metadata: ~\n        - add_docker_metadata:\n            host: \"unix:///var/run/docker.sock\"\n      \n      output.logstash:\n        hosts: [\"192.168.50.105:5044\"]\n      \n      filebeat.registry.path: /var/lib/filebeat/registry\n      logging.level: info\n      logging.to_files: true\n      logging.files:\n        path: /var/log/filebeat\n        name: filebeat\n        keepfiles: 7\n      \n      max_message_bytes: 999999\n      \n  - path: /opt/mcphub/.gitconfig\n    permissions: '0644'\n    owner: root:root\n    content: |\n      [safe]\n      \tdirectory = /home/jclee/dev/terraform\n      \tdirectory = /home/jclee/dev/blacklist\n      \tdirectory = /home/jclee/dev/oh-my-opencode\n      \tdirectory = /home/jclee/dev/prize\n      \tdirectory = /home/jclee/dev/propose\n      \tdirectory = /home/jclee/dev/resume\n      \tdirectory = /home/jclee/dev/safetywallet\n      \tdirectory = /home/jclee/dev/splunk\n      \tdirectory = /home/jclee/dev/tmux\n      \tdirectory = /home/jclee/dev/youtube\n      \n  - path: /opt/mcphub/patches/patch-placeholder.cjs\n    permissions: '0644'\n    owner: root:root\n    content: |\n      #!/usr/bin/env node\n      // Strips _placeholder from MCP tool arguments in mcpService.js at container startup.\n      // Origin: https://github.com/samanhappy/mcphub/pull/654 (closed without merge 2026-03-04)\n      // Permanent patch — upstream and MCP SDK do not handle _placeholder stripping.\n      \n      \"use strict\";\n      \n      const fs = require(\"fs\");\n      const MCPSERVICE = \"/app/dist/services/mcpService.js\";\n      \n      try {\n        if (!fs.existsSync(MCPSERVICE)) {\n          console.log(\"[patch] mcpService.js not found, skipping\");\n          process.exit(0);\n        }\n      \n        let code = fs.readFileSync(MCPSERVICE, \"utf8\");\n      \n        if (code.includes(\"sanitizeToolArguments\")) {\n          console.log(\"[patch] Already applied, skipping\");\n          process.exit(0);\n        }\n      \n        // Inject sanitize function at top of file\n        const sanitizeFn = [\n          \"// [PATCH] Strip _placeholder from MCP tool args (permanent — PR #654 closed unmerged)\",\n          \"function sanitizeToolArguments(args) {\",\n          '  if (!args || typeof args !== \"object\") return args;',\n          \"  const clean = { ...args };\",\n          \"  delete clean._placeholder;\",\n          \"  return Object.keys(clean).length === 0 ? {} : clean;\",\n          \"}\",\n          \"\",\n        ].join(\"\\n\");\n      \n        code = sanitizeFn + code;\n      \n        // Wrap argument-passing in callTool path (only finalArgs — toolArgs appears in destructuring)\n        code = code.replace(\n          /arguments:\\s*finalArgs\\b/g,\n          \"arguments: sanitizeToolArguments(finalArgs)\"\n        );\n      \n        fs.writeFileSync(MCPSERVICE, code);\n        console.log(\"[patch] _placeholder sanitization applied to mcpService.js\");\n      } catch (err) {\n        // Non-fatal — don't block container startup\n        console.error(\"[patch] Failed (non-fatal):\", err.message);\n        process.exit(0);\n      }\n      \n  - path: /opt/mcphub/patches/entrypoint-patch.sh\n    permissions: '0755'\n    owner: root:root\n    content: |\n      #!/bin/sh\n      # Entrypoint wrapper that applies runtime patches before starting MCPHub.\n      # Origin: https://github.com/samanhappy/mcphub/pull/654 (closed without merge 2026-03-04)\n      # Permanent patch — upstream and MCP SDK do not handle _placeholder stripping.\n      \n      set -e\n      \n      # Apply _placeholder sanitization patch\n      if [ -f /app/patches/patch-placeholder.cjs ]; then\n        node /app/patches/patch-placeholder.cjs\n      fi\n      \n      # Delegate to original entrypoint\n      exec /usr/local/bin/entrypoint.sh \"$@\"\n      \n\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - systemctl enable docker\n  - systemctl start docker\n  - # SSH hardening\n  - sed -i 's/^#\\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config\n  - sed -i 's/^#\\?PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config\n  - systemctl restart sshd\n  - # fail2ban SSH jail\n  - printf '[sshd]\\nenabled = true\\nport = ssh\\nfilter = sshd\\nmaxretry = 5\\nbantime = 3600\\n' \u003e /etc/fail2ban/jail.d/sshd.conf\n  - systemctl enable fail2ban\n  - systemctl start fail2ban\n  - mkdir -p /opt/mcphub\n  - mkdir -p /mnt/oc-dev /mnt/oc-kratos\n  - grep -q oc-dev /etc/fstab || echo 'jclee@192.168.50.200:/home/jclee/dev /mnt/oc-dev fuse.sshfs _netdev,allow_other,default_permissions,IdentityFile=/root/.ssh/id_rsa,reconnect,ServerAliveInterval=15,ServerAliveCountMax=3 0 0' \u003e\u003e /etc/fstab\n  - grep -q oc-kratos /etc/fstab || echo 'jclee@192.168.50.200:/home/jclee/.kratos /mnt/oc-kratos fuse.sshfs _netdev,allow_other,default_permissions,IdentityFile=/root/.ssh/id_rsa,reconnect,ServerAliveInterval=15,ServerAliveCountMax=3 0 0' \u003e\u003e /etc/fstab\n  - mountpoint -q /mnt/oc-dev || mount /mnt/oc-dev || true\n  - mountpoint -q /mnt/oc-kratos || mount /mnt/oc-kratos || true\n  - systemctl daemon-reload\n  - curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg\n  - echo 'deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main' \u003e /etc/apt/sources.list.d/google-cloud-sdk.list\n  - apt-get update \u0026\u0026 apt-get install -y google-cloud-cli\n  - mkdir -p /opt/mcphub/gcloud-config\n  - mkdir -p /opt/mcphub/patches\n  - cd /opt/mcphub \u0026\u0026 docker compose build \u0026\u0026 docker compose up -d\n\nfinal_message: \"Cloud-init completed for mcphub\"\n",
