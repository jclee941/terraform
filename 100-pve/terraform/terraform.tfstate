        {
          "index_key": "coredns-Corefile",
          "schema_version": 0,
          "attributes": {
            "content": "# CoreDNS configuration for split DNS\n# Resolves *.jclee.me to Traefik for internal clients\n# Resolves *.homelab.local to individual host IPs\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\n# All other *.jclee.me to Traefik\njclee.me:53 {\n    template IN A {\n        match \"^([a-z0-9-]+)\\.jclee.me\\.$\"\n        answer \"{{ .Name }} 60 IN A 192.168.50.102\"\n        fallthrough\n    }\n    template IN AAAA {\n        rcode NOERROR\n    }\n    log\n}\n\nhomelab.local:53 {\n    hosts {\n        192.168.50.108 archon.homelab.local\n        192.168.50.114 cliproxy.homelab.local\n        192.168.50.103 coredns.homelab.local\n        192.168.50.105 elk.homelab.local\n        192.168.50.101 gitlab-runner.homelab.local\n        192.168.50.104 grafana.homelab.local\n        192.168.50.80 jclee.homelab.local\n        192.168.50.200 jclee-dev.homelab.local\n        192.168.50.112 mcphub.homelab.local\n        192.168.50.110 n8n.homelab.local\n        192.168.50.100 pve.homelab.local\n        192.168.50.107 supabase.homelab.local\n        192.168.50.215 synology.homelab.local\n        192.168.50.102 traefik.homelab.local\n        192.168.50.220 youtube.homelab.local\n        fallthrough\n    }\n    log\n}\n\n.:53 {\n    forward . 1.1.1.1 8.8.8.8\n    cache 300\n    log\n    errors\n    health :8080\n    ready :8181\n}\n",
            "content_base64": null,
            "content_base64sha256": "OHjpjhyvPDKLQ3+RWmidyMwVZRQZWUp7yipi3KluWwM=",
            "content_base64sha512": "db2T3JKI6AGboQTjF+AUj85cYrwONaqXkkbQBMAR+8AvIoqBe2jdR+JSfAEayVdFmNMdGzR0O/vW+SSsc0wHYg==",
