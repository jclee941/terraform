          "identity_schema_version": 0,
          "dependencies": [
            "module.onepassword_secrets.data.onepassword_item.archon",
            "module.onepassword_secrets.data.onepassword_item.cloudflare",
            "module.onepassword_secrets.data.onepassword_item.elk",
            "module.onepassword_secrets.data.onepassword_item.exa",
            "module.onepassword_secrets.data.onepassword_item.github",
            "module.onepassword_secrets.data.onepassword_item.glitchtip",
            "module.onepassword_secrets.data.onepassword_item.grafana",
            "module.onepassword_secrets.data.onepassword_item.mcphub",
