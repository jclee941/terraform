        {
          "index_key": "supabase-filebeat.yml",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 107-supabase (Supabase BaaS)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n      # Hint annotations for supabase containers — auto-tag each component\n      templates:\n        - condition:\n            or:\n              - contains:\n                  docker.container.name: supabase-kong\n              - contains:\n                  docker.container.name: supabase-auth\n              - contains:\n                  docker.container.name: supabase-rest\n              - contains:\n                  docker.container.name: supabase-realtime\n              - contains:\n                  docker.container.name: supabase-storage\n              - contains:\n                  docker.container.name: supabase-db\n              - contains:\n                  docker.container.name: supabase-studio\n              - contains:\n                  docker.container.name: supabase-meta\n              - contains:\n                  docker.container.name: supabase-edge-functions\n              - contains:\n                  docker.container.name: supabase-analytics\n          config:\n            - type: container\n              paths:\n                - /var/lib/docker/containers/${data.docker.container.id}/*.log\n              fields:\n                service: supabase\n                supabase_component: \"${data.docker.container.name}\"\n                host_role: supabase\n              fields_under_root: false\n\nfilebeat.inputs:\n  # Docker container logs (catch-all for all containers)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: supabase\n      host_role: supabase\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: system\n      host_role: supabase\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "QRhCSkdd0OUEdlAlSl8Rw9KHRuxdzSX28Bte78vcTnY=",
            "content_base64sha512": "rjiWDzoPa4NOuWXtjQ6iSUUlfM0A9WtO7D3QQfowox/AywpqrsRkpuFLIehzgNCONnLoAUfLEesDgWkmH6/IVw==",
