        {
          "index_key": "n8n-Dockerfile.n8n",
          "schema_version": 0,
          "attributes": {
            "content": "FROM n8nio/n8n:2.8.1\n\n# Enterprise license patches — enable all features for self-hosted deployment\n# Patched methods: isLicensed() → true, getValue() → UNLIMITED_LICENSE_QUOTA,\n# getPlanName() → 'Enterprise', getMainPlan() → mock entitlement, getInfo() → 'Enterprise (patched)'\nCOPY patches/license.js /usr/local/lib/node_modules/n8n/dist/license.js\n\n# Patched methods: isLicensed() → true, getValue() → UNLIMITED with special time-based quota handling\nCOPY patches/license-state.js /usr/local/lib/node_modules/n8n/node_modules/.pnpm/@n8n+backend-common@file+packages+@n8n+backend-common/node_modules/@n8n/backend-common/dist/license-state.js\n",
