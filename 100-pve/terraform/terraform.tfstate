        {
          "index_key": "archon",
          "schema_version": 0,
          "attributes": {
            "content": "services:\n  archon-server:\n    build:\n      context: ./python\n      dockerfile: Dockerfile.server\n    container_name: archon-server\n    ports:\n      - \"8181:8181\"\n    environment:\n      - SUPABASE_URL=https://placeholder.supabase.local\n      - SUPABASE_ANON_KEY=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\n      - OPENAI_API_KEY=placeholder\n      - SERVICE_DISCOVERY_MODE=docker_compose\n      - LOG_LEVEL=INFO\n      - ARCHON_SERVER_PORT=8181\n      - ARCHON_MCP_PORT=8051\n      - ARCHON_UI_PORT=3737\n      - ARCHON_HOST=0.0.0.0\n    networks:\n      - app-network\n    command:\n      [\n        \"python\",\n        \"-m\",\n        \"uvicorn\",\n        \"src.server.main:app\",\n        \"--host\",\n        \"0.0.0.0\",\n        \"--port\",\n        \"8181\"\n      ]\n    healthcheck:\n      test: [\"CMD\", \"curl\", \"-f\", \"http://localhost:8181/health\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 40s\n    restart: unless-stopped\n\n  archon-mcp:\n    build:\n      context: ./python\n      dockerfile: Dockerfile.mcp\n    container_name: archon-mcp\n    ports:\n      - \"8051:8051\"\n    environment:\n      - SUPABASE_URL=https://placeholder.supabase.local\n      - SUPABASE_ANON_KEY=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\n      - OPENAI_API_KEY=placeholder\n      - TRANSPORT=sse\n      - ARCHON_MCP_PORT=8051\n      - ARCHON_SERVER_PORT=8181\n    networks:\n      - app-network\n    depends_on:\n      archon-server:\n        condition: service_healthy\n    restart: unless-stopped\n\n  archon-frontend:\n    build: ./archon-ui-main\n    container_name: archon-ui\n    ports:\n      - \"3737:3737\"\n    environment:\n      - VITE_ARCHON_SERVER_PORT=8181\n      - ARCHON_SERVER_PORT=8181\n      - HOST=0.0.0.0\n      - PROD=false\n      - DOCKER_ENV=true\n    networks:\n      - app-network\n    depends_on:\n      archon-server:\n        condition: service_healthy\n    restart: unless-stopped\n\nnetworks:\n  app-network:\n    driver: bridge\n",
            "content_base64": null,
