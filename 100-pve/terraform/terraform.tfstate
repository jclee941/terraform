            "content": "http:\n  routers:\n    n8n:\n      rule: Host(`n8n.jclee.me`)\n      entryPoints:\n        - websecure\n      service: n8n\n      middlewares:\n        - rate-limit-api@file\n        - chain-basic-auth@file\n      tls:\n        certResolver: cf\n      priority: 10\n\n    n8n-http:\n      rule: Host(`n8n.jclee.me`)\n      entryPoints:\n        - web\n      service: n8n\n      priority: 10\n\n    n8n-webhook:\n      rule: Host(`n8n.jclee.me`) \u0026\u0026 PathPrefix(`/webhook`)\n      entryPoints:\n        - websecure\n      service: n8n\n      middlewares:\n        - rate-limit-api@file\n      tls:\n        certResolver: cf\n      priority: 100\n\n    n8n-webhook-http:\n      rule: Host(`n8n.jclee.me`) \u0026\u0026 PathPrefix(`/webhook`)\n      entryPoints:\n        - web\n      service: n8n\n      priority: 100\n\n  services:\n    n8n:\n      loadBalancer:\n        servers:\n          - url: http://192.168.50.110:5678\n",
