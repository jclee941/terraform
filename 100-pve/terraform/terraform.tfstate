          "schema_version": 0,
          "attributes": {
            "content": "api:\n  dashboard: true\n  insecure: true\n\nmetrics:\n  prometheus:\n    addEntryPointsLabels: true\n    addRoutersLabels: true\n    addServicesLabels: true\n\nentryPoints:\n  web:\n    address: \":80\"\n  websecure:\n    address: \":443\"\n\nproviders:\n  docker:\n    endpoint: \"unix:///var/run/docker.sock\"\n    exposedByDefault: false\n  file:\n    directory: /etc/traefik/dynamic\n    watch: true\n\ncertificatesResolvers:\n  letsencrypt:\n    acme:\n      email: jclee@jclee.me\n      storage: /etc/traefik/acme.json\n      httpChallenge:\n        entryPoint: web\n  cf:\n    acme:\n      email: jclee@jclee.me\n      storage: /etc/traefik/acme-cf.json\n      dnsChallenge:\n        provider: cloudflare\n        resolvers:\n          - \"1.1.1.1:53\"\n          - \"8.8.8.8:53\"\n",
            "content_base64": null,
            "content_base64sha256": "HQUAnqRnPG6EuX/SnzXav+YujLSqsbd1fc+6FOmXTEI=",
            "content_base64sha512": "wslbovO45Gtj/BdR+dzLoj12Av7ehp8umkSbp0me5bAvHRFH8X5WHL8IWA8tRscmCOFjjlhs5g1OxsC75rF4GQ==",
