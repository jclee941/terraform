        {
          "index_key": "n8n_docker_compose",
          "schema_version": 0,
          "attributes": {
            "content": "services:\n  n8n:\n    container_name: n8n\n    build:\n      context: /opt/n8n\n      dockerfile: Dockerfile.n8n\n    restart: unless-stopped\n    env_file:\n      - ./n8n.env\n    ports:\n      - \"5678:5678\"\n    depends_on:\n      postgres:\n        condition: service_healthy\n    deploy:\n      resources:\n        limits:\n          memory: 1G\n          cpus: '1.00'\n    logging:\n      driver: json-file\n      options:\n        max-size: \"50m\"\n        max-file: \"5\"\n    healthcheck:\n      test: [\"CMD-SHELL\", \"curl -sf http://localhost:5678/healthz || exit 1\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 30s\n    volumes:\n      - n8n_data:/home/node/.n8n\n    networks:\n      - n8n_default\n\n  postgres:\n    image: postgres:16-alpine\n    container_name: n8n-postgres\n    environment:\n      POSTGRES_DB: n8n\n      POSTGRES_USER: n8n\n      POSTGRES_PASSWORD: ncR9fdvI13RCnguYuxGJ7iSi\n    volumes:\n      - n8n_postgres_data:/var/lib/postgresql/data\n    healthcheck:\n      test: [\"CMD-SHELL\", \"pg_isready -U n8n -d n8n\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n    restart: unless-stopped\n    networks:\n      - n8n_default\n\n  cadvisor:\n    image: gcr.io/cadvisor/cadvisor:v0.51.0\n    container_name: n8n-cadvisor\n    ports:\n      - \"8888:8080\"\n    volumes:\n      - /:/rootfs:ro\n      - /var/run:/var/run:ro\n      - /sys:/sys:ro\n      - /var/lib/docker/:/var/lib/docker:ro\n    restart: unless-stopped\n    networks:\n      - n8n_default\n\n  postgres-exporter:\n    image: prometheuscommunity/postgres-exporter:v0.16.0\n    container_name: n8n-postgres-exporter\n    environment:\n      DATA_SOURCE_NAME: postgresql://n8n:ncR9fdvI13RCnguYuxGJ7iSi@postgres:5432/n8n?sslmode=disable\n    ports:\n      - \"9187:9187\"\n    depends_on:\n      postgres:\n        condition: service_healthy\n    restart: unless-stopped\n    networks:\n      - n8n_default\n\nvolumes:\n  n8n_data:\n    driver: local\n  n8n_postgres_data:\n    driver: local\n\nnetworks:\n  n8n_default:\n    name: n8n_default\n    driver: bridge\n",
            "content_base64": null,
            "content_base64sha256": "dbKftsLI5eF/qG8Qjn1ssb1BTGAytJwCFMmwhsLoUhw=",
            "content_base64sha512": "p4aMyhi+yUlKbEkyUmyROh/h/qFQGjAeh7IUDWF7/nVeEg6DFduMn/5JwhiiumYfuVhcRF6IvZ2eqpnhpAAvJA==",
