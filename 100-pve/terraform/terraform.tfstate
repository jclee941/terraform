        {
          "index_key": "n8n_env",
          "schema_version": 0,
          "attributes": {
            "content": "# ── Database (PostgreSQL) ──\nDB_TYPE=postgresdb\nDB_POSTGRESDB_HOST=postgres\nDB_POSTGRESDB_PORT=5432\nDB_POSTGRESDB_DATABASE=n8n\nDB_POSTGRESDB_USER=n8n\nDB_POSTGRESDB_PASSWORD=ncR9fdvI13RCnguYuxGJ7iSi\nN8N_ENCRYPTION_KEY=aa9001f428beb62ae0a5c490e2d4b5b7c7350f8a6feb722b7818020415490ef2\n\n# ── Core ──\nN8N_HOST=n8n.jclee.me\nN8N_PORT=5678\nN8N_PROTOCOL=https\nN8N_SECURE_COOKIE=false\nTZ=Asia/Seoul\nWEBHOOK_URL=https://n8n.jclee.me/\n\n# ── API (1Password: n8n → api_key) ──\nN8N_API_ENABLED=true\nN8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxM2E5NTg0NS1hNDZhLTQ4NTUtYjcwNi1lYWRhZGEwZGQwNGMiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwianRpIjoiZGMxYzQyNDgtZTg3OC00NDdhLTgwMjctMjBkM2Y4YmNjN2EwIiwiaWF0IjoxNzczOTQzOTEzfQ.wFmGxBf53j3zX67fIBDP-0f5tLRBwadSCOBQXxOmlmU\n\n# ── Features ──\nN8N_COMMUNITY_PACKAGES_ENABLED=true\nN8N_TEMPLATES_ENABLED=true\nN8N_VERSION_NOTIFICATIONS_ENABLED=true\nN8N_PERSONALIZATION_ENABLED=true\nN8N_HIRING_BANNER_ENABLED=false\nN8N_DIAGNOSTICS_ENABLED=false\n\n# ── Metrics (Prometheus /metrics) ──\nN8N_METRICS=true\nN8N_METRICS_INCLUDE_DEFAULT_METRICS=true\nN8N_METRICS_INCLUDE_API_ENDPOINTS=true\nN8N_METRICS_INCLUDE_API_PATH_LABEL=true\nN8N_METRICS_INCLUDE_API_METHOD_LABEL=true\nN8N_METRICS_INCLUDE_API_STATUS_CODE_LABEL=true\nN8N_METRICS_INCLUDE_CACHE_METRICS=true\nN8N_METRICS_INCLUDE_MESSAGE_EVENT_BUS_METRICS=true\nN8N_METRICS_INCLUDE_WORKFLOW_ID_LABEL=true\nN8N_METRICS_INCLUDE_NODE_TYPE_LABEL=true\nN8N_METRICS_INCLUDE_CREDENTIAL_TYPE_LABEL=true\n\n# ── Execution ──\nEXECUTIONS_DATA_SAVE_ON_ERROR=all\nEXECUTIONS_DATA_SAVE_ON_SUCCESS=all\nEXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true\nEXECUTIONS_DATA_PRUNE=true\nEXECUTIONS_DATA_MAX_AGE=336\nN8N_EXECUTION_TIMEOUT=300\n\n# ── Logging ──\nN8N_LOG_LEVEL=info\nN8N_LOG_OUTPUT=console\n\n# ── External integrations ──\nGITHUB_TOKEN=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\nSLACK_BOT_TOKEN=xoxb-9906625333574-10531905908103-r6DstzjigyzaE3UMe4yTmbPo\nSUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogInNlcnZpY2Vfcm9sZSIsICJpc3MiOiAic3VwYWJhc2UiLCAiaWF0IjogMTc3MTYwMDgwMCwgImV4cCI6IDIwODY5NjA4MDB9.vLTEQu-8UATji7axVljZzlmPUrbqbFmx7fjXaQc580Y\nYOUTUBE_GOOGLE_CLIENT_ID=\nYOUTUBE_GOOGLE_CLIENT_SECRET=\nYOUTUBE_GOOGLE_REFRESH_TOKEN=\n\n# ── Official n8n Node Integration ──\nTELEGRAM_BOT_TOKEN=8430418484:AAEtb7NsZMuL46-qpMTCyam1svTbW5W6B5o\n\n# ── Payload ──\nN8N_PAYLOAD_SIZE_MAX=16\n\n# Allow $env access in workflow nodes (required for YouTube pipeline workflows)\nN8N_BLOCK_ENV_ACCESS_IN_NODE=false\n\n# ── YouTube Pipeline Integration ──\nSUPABASE_URL=http://192.168.50.107:8000\nSUPABASE_ANON_KEY=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\nFFMPEG_WORKER_URL=http://192.168.50.220:8080\n\n# Workflow IDs (assigned at import time; update after re-import)\nPIPELINE_ORCHESTRATOR_WORKFLOW_ID=kWW5947tHQ8RqMFi\nQUEUE_EXECUTOR_WORKFLOW_ID=kRRZAx7krkcaCcpT\nSLACK_NOTIFIER_WORKFLOW_ID=PV5yLgHNzNSlCmRT\n\n# Slack webhook for pipeline notifications (create via Slack Incoming Webhooks app)\n# SLACK_WEBHOOK_URL=\n\n# ── Git SSL Verification Bypass (for self-signed GitLab) ──\nGIT_SSL_NO_VERIFY=true\nNODE_TLS_REJECT_UNAUTHORIZED=0\n",
            "content_base64": null,
            "content_base64sha256": "2122fUXUxSBsWmtanPpH5g3vtPMXaJSME/zzekr+SEI=",
            "content_base64sha512": "LXCcYZpui/w5uT27vws72oJ4pACGYn3ztobXvm6yXczNtvmpnEcmmL6a3XZiEurwrOofZWBpWKFlgotne6zQgw==",
