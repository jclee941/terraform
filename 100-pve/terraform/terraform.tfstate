        {
          "index_key": "traefik_middlewares",
          "schema_version": 0,
          "attributes": {
            "content": "# Traefik Dynamic Configuration - Middleware Definitions\n# Includes resilient chain, rate limiting, security headers, and basic auth.\n#\n# Usage: Reference middlewares via @file suffix in route configs:\n#   middlewares:\n#     - chain-basic-auth@file\n#     - rate-limit-api@file\n\nhttp:\n  middlewares:\n    # Retry failed requests up to 5 times with exponential backoff\n    mcp-retry:\n      retry:\n        attempts: 5\n        initialInterval: 100ms\n\n    # Trip circuit breaker on high error rates\n    mcp-circuit-breaker:\n      circuitBreaker:\n        expression: \"NetworkErrorRatio() \u003e 0.30 || ResponseCodeRatio(500, 600, 0, 600) \u003e 0.25\"\n\n    # Combined resilient chain: retry first, then circuit breaker\n    mcp-resilient:\n      chain:\n        middlewares:\n          - mcp-retry\n          - mcp-circuit-breaker\n\n    # Rate limiting for external-facing endpoints\n    rate-limit:\n      rateLimit:\n        average: 100\n        burst: 50\n        period: 1s\n\n    # Per-service rate limiting tiers\n    rate-limit-api:\n      rateLimit:\n        average: 30\n        burst: 15\n        period: 1s\n\n    rate-limit-standard:\n      rateLimit:\n        average: 60\n        burst: 30\n        period: 1s\n\n    rate-limit-relaxed:\n      rateLimit:\n        average: 120\n        burst: 60\n        period: 1s\n\n    # Security headers for all external-facing routes\n    security-headers:\n      headers:\n        stsSeconds: 31536000\n        stsIncludeSubdomains: true\n        stsPreload: true\n        frameDeny: true\n        contentTypeNosniff: true\n        browserXssFilter: true\n        referrerPolicy: strict-origin-when-cross-origin\n        permissionsPolicy: camera=(), microphone=(), geolocation=(), payment=()\n        contentSecurityPolicy: \"default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' wss: https:; frame-ancestors 'self'\"\n\n    # BasicAuth for internal browser-accessible services\n    basic-auth:\n      basicAuth:\n        users:\n          - \"admin:$2y$10$vu1uqdsZG3.qn69ow2SK.egtD9.gDo7p9/AKLO/j/R5lo1bZwod5C\"\n\n    # Chain: security headers + basic auth (required per AGENTS.md convention)\n    chain-basic-auth:\n      chain:\n        middlewares:\n          - security-headers\n          - basic-auth\n",
            "content_base64": null,
            "content_base64sha256": "GH4gqetIGzJZTgfmgCEHdinZr07Tx41ByrdbTcFTL6M=",
            "content_base64sha512": "7AiGlzNSQnBuMb0VNWsd7dD/CyvFgXA12yE/0GFattes8+c8OVaK1ijUiEWoSRhStEJr7g1lRmaLy3TEMIIg8w==",
            "content_md5": "d51819eab68bfad32bbb858e58495d78",
            "content_sha1": "73e2b1d796ea0d0a1137914a2ca5ad66430beebc",
            "content_sha256": "187e20a9eb481b32594e07e68021077629d9af4ed3c78d41cab75b4dc1532fa3",
            "content_sha512": "ec088697335242706e31bd15356b1dedd0ff0b2bc5817035db213fd0615ab6d7acf3e73c39568ad628d48845a8491852b4426bee0d6546668bcb74c4308220f3",
            "directory_permission": "0777",
