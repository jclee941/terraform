        {
          "index_key": "elk-logstash.yml",
          "schema_version": 0,
          "attributes": {
            "content": "http.host: \"0.0.0.0\"\nxpack.monitoring.elasticsearch.hosts:\n  - \"http://elasticsearch:9200\"\nxpack.monitoring.elasticsearch.username: \"${ELASTICSEARCH_USERNAME}\"\nxpack.monitoring.elasticsearch.password: \"${ELASTICSEARCH_PASSWORD}\"\ndead_letter_queue.enable: true\ndead_letter_queue.max_bytes: \"1024mb\"\n",
            "content_base64": null,
            "content_base64sha256": "RpkYmXYCvts8LeLMHf2f3ZiFZYaVkANG2boTrwluHgg=",
            "content_base64sha512": "RtL0qKyunIZif6ytdYGv4oo35ef7XdfX0OnFAhKit5viU5+quEPfEHM8zL6CheeugFb7v2aut9mCJEInSZ9TbA==",
