        {
          "index_key": "mcphub_docker_compose",
          "schema_version": 0,
          "attributes": {
            "content": "services:\n  mcphub:\n    image: samanhappy/mcphub:0.12.6\n    container_name: mcphub\n    restart: unless-stopped\n    ports:\n      - \"3000:3000\"\n    volumes:\n      - ./mcp_settings.json:/app/mcp_settings.json\n      - mcphub_data:/app/data\n      - npm_cache:/root/.npm\n      - /usr/bin/op:/usr/bin/op:ro\n      - ./op-mcp-server:/app/op-mcp-server:ro\n      - /mnt/oc-dev:/home/jclee/dev\n      - ./.gitconfig:/root/.gitconfig:ro\n      - /mnt/oc-kratos:/root/.kratos\n      - ./patches:/app/patches:ro\n      - /usr/lib/google-cloud-sdk:/usr/lib/google-cloud-sdk:ro\n      - /usr/bin/gcloud:/usr/bin/gcloud:ro\n      - ./gcloud-config:/root/.config/gcloud\n    env_file:\n      - .env\n    environment:\n      - MCPHUB_PORT=3000\n    entrypoint: [\"/app/patches/entrypoint-patch\"]\n    command: [\"pnpm\", \"start\"]\n    healthcheck:\n      test: [\"CMD-SHELL\", \"curl -sf http://localhost:3000/ || exit 1\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 30s\n    depends_on:\n      - mcp-proxmox\n      - mcp-playwright\n      - mcp-dev-browser\n\n  mcp-proxmox:\n    build:\n      context: .\n      dockerfile: Dockerfile.proxmox\n    container_name: mcp-proxmox\n    restart: unless-stopped\n    ports:\n      - \"8055:8055\"\n    env_file:\n      - .env\n    healthcheck:\n      test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8055,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 15s\n\n  mcp-playwright:\n    build:\n      context: .\n      dockerfile: Dockerfile.playwright\n    container_name: mcp-playwright\n    restart: unless-stopped\n    ports:\n      - \"8056:8056\"\n    env_file:\n      - .env\n    environment:\n      - PLAYWRIGHT_MCP_HEADLESS=true\n    healthcheck:\n      test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8056,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 15s\n\n  mcp-dev-browser:\n    build:\n      context: .\n      dockerfile: Dockerfile.dev-browser\n    container_name: mcp-dev-browser\n    restart: unless-stopped\n    ports:\n      - \"8057:8057\"\n    env_file:\n      - .env\n    environment:\n      - HOST=0.0.0.0\n      - PORT=8057\n      - RELAY_MODE=auto\n    healthcheck:\n      test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8057,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 15s\n\n  cadvisor:\n    image: gcr.io/cadvisor/cadvisor:v0.51.0\n    container_name: cadvisor\n    ports:\n      - \"8888:8080\"\n    volumes:\n      - /:/rootfs:ro\n      - /var/run:/var/run:ro\n      - /sys:/sys:ro\n      - /var/lib/docker/:/var/lib/docker:ro\n    deploy:\n      resources:\n        limits:\n          memory: 128M\n          cpus: '0.25'\n    logging:\n      driver: json-file\n      options:\n        max-size: \"10m\"\n        max-file: \"3\"\n    restart: unless-stopped\n\nvolumes:\n  mcphub_data:\n  npm_cache:\n",
            "content_base64": null,
            "content_base64sha256": "01qALSZrwu3oYEj7CNehdZX3y+n/73oWSixexIssFF4=",
            "content_base64sha512": "VAb3WCK2OsT6Iwp/SGU0sNPvZNU630jLq61dP32P3FMC1JGKFpRA66e0re3dsm1g3j94QWTom3jLmdBiuw+EjQ==",
