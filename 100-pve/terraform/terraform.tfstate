        {
          "index_key": "prometheus",
          "schema_version": 0,
          "attributes": {
            "content": "global:\n  scrape_interval: 15s\n  evaluation_interval: 15s\n\nscrape_configs:\n  - job_name: 'prometheus'\n    static_configs:\n      - targets: ['localhost:9090']\n\n  - job_name: 'node'\n    static_configs:\n      - targets: ['192.168.50.104:9100']\n\n  - job_name: 'traefik'\n    static_configs:\n      - targets: ['192.168.50.102:8080']\n\n  - job_name: 'infrastructure-nodes'\n    static_configs:\n      - targets:\n          - '192.168.50.108:9100'\n          - '192.168.50.114:9100'\n          - '192.168.50.103:9100'\n          - '192.168.50.105:9100'\n          - '192.168.50.101:9100'\n          - '192.168.50.104:9100'\n          - '192.168.50.112:9100'\n          - '192.168.50.110:9100'\n          - '192.168.50.107:9100'\n          - '192.168.50.102:9100'\n          - '192.168.50.220:9100'\n          - '192.168.50.103:9100'\n          - '192.168.50.110:9100'\n    relabel_configs:\n      - source_labels: [__address__]\n        regex: '192\\.168\\.50\\.(\\d+):.*'\n        replacement: '${1}'\n        target_label: vmid\n\n  - job_name: 'logstash'\n    metrics_path: /metrics\n    static_configs:\n      - targets: ['192.168.50.105:9198']\n        labels:\n          service: logstash\n\n  - job_name: 'blackbox-http'\n    metrics_path: /probe\n    params:\n      module: [http_2xx]\n    static_configs:\n      - targets:\n          - 'http://192.168.50.110:5678/healthz'\n          - 'http://192.168.50.112:3000/'\n          - 'http://192.168.50.102:8080/api/overview'\n          - 'http://elastic:I93bmZ/uT3haNpdL9GJ+neTf@192.168.50.105:9200/_cluster/health'\n          - 'http://192.168.50.104:3000/api/health'\n          - 'http://192.168.50.107:8000/rest/v1/'\n          - 'http://192.168.50.108:3737/'\n          - 'http://192.168.50.103:8080/'\n          - 'http://192.168.50.112:8090/heartbeat'\n    relabel_configs:\n      - source_labels: [__address__]\n        target_label: __param_target\n      - source_labels: [__param_target]\n        target_label: instance\n      - target_label: __address__\n        replacement: blackbox-exporter:9115\n\n  - job_name: 'blackbox-https'\n    metrics_path: /probe\n    params:\n      module: [http_2xx]\n    static_configs:\n      - targets:\n          - 'https://grafana.jclee.me'\n          - 'https://archon.jclee.me'\n          - 'https://supabase.jclee.me'\n    relabel_configs:\n      - source_labels: [__address__]\n        target_label: __param_target\n      - source_labels: [__param_target]\n        target_label: instance\n      - target_label: __address__\n        replacement: blackbox-exporter:9115\n\n  - job_name: 'cadvisor'\n    static_configs:\n      - targets:\n          - '192.168.50.104:8888'\n          - '192.168.50.112:8888'\n          - '192.168.50.220:8888'\n          - '192.168.50.110:8888'\n    relabel_configs:\n      - source_labels: [__address__]\n        regex: '192\\.168\\.50\\.(\\d+):.*'\n        replacement: '${1}'\n        target_label: vmid\n\n  - job_name: 'postgres-exporter'\n    static_configs:\n      - targets:\n          - '192.168.50.107:9187'\n          - '192.168.50.110:9187'\n    relabel_configs:\n      - source_labels: [__address__]\n        regex: '192\\.168\\.50\\.(\\d+):.*'\n        replacement: '${1}'\n        target_label: vmid\n",
            "content_base64": null,
