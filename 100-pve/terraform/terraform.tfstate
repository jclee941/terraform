        {
          "index_key": "youtube",
          "schema_version": 0,
          "attributes": {
            "content": "#cloud-config\nhostname: youtube\nmanage_etc_hosts: true\n\npackage_update: true\npackage_upgrade: false\n\npackages:\n  - qemu-guest-agent\n  - curl\n  - vim\n  - git\n  - gnupg\n  - docker.io\n  - docker-compose-v2\n  - fail2ban\n\nwrite_files:\n  - path: /etc/filebeat/filebeat.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      # Filebeat configuration for 220-youtube (YouTube Media Server)\n      # Rendered by Terraform - DO NOT EDIT MANUALLY\n      \n      filebeat.autodiscover:\n        providers:\n          - type: docker\n            hints.enabled: true\n      \n      filebeat.inputs:\n        # Docker container logs (media services, watchtower)\n        - type: filestream\n          id: docker-containers\n          paths:\n            - /var/lib/docker/containers/*/*.log\n          parsers:\n            - container: {}\n          prospector.scanner.symlinks: true\n          fields:\n            service: youtube\n            host_role: youtube\n          fields_under_root: false\n      \n        # System logs\n        - type: filestream\n          id: system-logs\n          paths:\n            - /var/log/*.log\n            - /var/log/syslog\n          fields:\n            service: youtube\n            host_role: youtube\n          fields_under_root: false\n      \n      processors:\n        - add_host_metadata: ~\n        - add_docker_metadata:\n            host: \"unix:///var/run/docker.sock\"\n      \n      output.logstash:\n        hosts: [\"192.168.50.105:5044\"]\n      \n      filebeat.registry.path: /var/lib/filebeat/registry\n      logging.level: info\n      logging.to_files: true\n      logging.files:\n        path: /var/log/filebeat\n        name: filebeat\n        keepfiles: 7\n      \n      max_message_bytes: 999999\n      \n  - path: /opt/youtube/docker-compose.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      # Generated by Terraform. DO NOT EDIT MANUALLY.\n      services:\n        youtube-automation:\n          image: alpine:latest\n          container_name: youtube-automation\n          restart: unless-stopped\n          network_mode: bridge\n          stop_grace_period: 10s\n          env_file:\n            - .env\n          volumes:\n            - ./gcloud-config:/root/.config/gcloud\n          healthcheck:\n            test: [\"CMD-SHELL\", \"ps aux | grep -v grep | grep -q 'tail -f' || exit 1\"]\n            interval: 30s\n            timeout: 5s\n            retries: 3\n            start_period: 10s\n          logging:\n            driver: json-file\n            options:\n              max-size: \"10m\"\n              max-file: \"3\"\n          command: [\"sh\", \"-c\", \"tail -f /dev/null\"]\n      \n        cadvisor:\n          image: gcr.io/cadvisor/cadvisor:v0.51.0\n          container_name: cadvisor\n          ports:\n            - \"8888:8080\"\n          volumes:\n            - /:/rootfs:ro\n            - /var/run:/var/run:ro\n            - /sys:/sys:ro\n            - /var/lib/docker/:/var/lib/docker:ro\n          deploy:\n            resources:\n              limits:\n                memory: 128M\n                cpus: '0.25'\n          logging:\n            driver: json-file\n            options:\n              max-size: \"10m\"\n              max-file: \"3\"\n          restart: unless-stopped\n      \n  - path: /opt/youtube/.env\n    permissions: '0600'\n    owner: root:root\n    content: |\n      # YouTube Automation - Terraform Rendered Environment Configuration\n      # Generated by Terraform. DO NOT EDIT MANUALLY.\n      # Template: 220-youtube/templates/.env.tftpl\n      \n      # Google OAuth Credentials\n      GOOGLE_CLIENT_ID=\n      GOOGLE_CLIENT_SECRET=\n      GOOGLE_REFRESH_TOKEN=\n      GOOGLE_PROJECT_ID=\n      \n      # YouTube\n      YOUTUBE_CHANNEL_ID=\n      \n\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - systemctl enable docker\n  - systemctl start docker\n  - # SSH hardening\n  - sed -i 's/^#\\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config\n  - sed -i 's/^#\\?PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config\n  - systemctl restart sshd\n  - # fail2ban SSH jail\n  - printf '[sshd]\\nenabled = true\\nport = ssh\\nfilter = sshd\\nmaxretry = 5\\nbantime = 3600\\n' \u003e /etc/fail2ban/jail.d/sshd.conf\n  - systemctl enable fail2ban\n  - systemctl start fail2ban\n  - # Google Cloud CLI\n  - curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg\n  - echo 'deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main' | tee /etc/apt/sources.list.d/google-cloud-sdk.list\n  - apt-get update \u0026\u0026 apt-get install -y google-cloud-cli\n  - # YouTube automation setup\n  - mkdir -p /opt/youtube/gcloud-config\n  - cd /opt/youtube \u0026\u0026 docker compose up -d || true\n\nfinal_message: \"Cloud-init completed for youtube\"\n",
            "content_base64": null,
            "content_base64sha256": "S4GgU9paATmldlAWhCGva0B/Z43ISjFCpOKHbb/Y7kQ=",
            "content_base64sha512": "bvVtWbJ9EKIZ/XJec0qnh2LJq2F0d27HNSkn43DP3DRrmyHe6tvYF+LVOx0tguD41bwtnPx/cvqvpFw9HTWFkA==",
            "content_md5": "dbd0ea5cb42bada7f215afe9313e9c0e",
            "content_sha1": "b60220d74d96409c8242f4ecc3dc2324034a6adb",
