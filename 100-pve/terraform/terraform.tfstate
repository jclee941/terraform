        {
          "index_key": "traefik_archon",
          "schema_version": 0,
          "attributes": {
            "content": "http:\n  routers:\n    archon:\n      rule: Host(`archon.jclee.me`)\n      entryPoints:\n        - websecure\n      service: archon\n      middlewares:\n        - rate-limit-api@file\n        - chain-basic-auth@file\n      tls:\n        certResolver: cf\n      priority: 10\n\n    archon-http:\n      rule: Host(`archon.jclee.me`)\n      entryPoints:\n        - web\n      service: archon\n      priority: 10\n\n  services:\n    archon:\n      loadBalancer:\n        servers:\n          - url: http://192.168.50.108:3737\n",
