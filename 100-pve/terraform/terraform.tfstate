        {
          "index_key": "runner_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 101-runner (GitHub Actions Self-hosted Runner)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.inputs:\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: runner\n      host_role: runner\n    fields_under_root: false\n\n  # GitHub Actions Runner diagnostic logs\n  - type: filestream\n    id: runner-diag-logs\n    paths:\n      - /home/runner/runners/*/_diag/*.log\n    fields:\n      service: runner\n      host_role: runner\n    fields_under_root: false\n\n  # Auth logs\n  - type: filestream\n    id: auth-logs\n    paths:\n      - /var/log/auth.log\n    fields:\n      service: auth\n      host_role: runner\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "VZedAL9LuTXjrZ+/7c4DcZSd46FTKBe4PJDCAnBFbLI=",
