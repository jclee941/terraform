        {
          "index_key": "mcphub_mcp_settings",
          "schema_version": 0,
          "attributes": {
            "content": "{\"mcpServers\":{\"archon\":{\"type\":\"streamable-http\",\"url\":\"http://192.168.50.108:8051/mcp\"},\"elk\":{\"args\":[\"-y\",\"@awesome-ai/elasticsearch-mcp\"],\"command\":\"npx\",\"env\":{\"ES_HOST\":\"${ES_HOST}\",\"ES_PASSWORD\":\"${ES_PASSWORD}\",\"ES_USERNAME\":\"${ES_USERNAME}\"}},\"git\":{\"args\":[\"-y\",\"@mseep/git-mcp-server\"],\"command\":\"npx\"},\"github\":{\"args\":[\"-y\",\"@modelcontextprotocol/server-github\"],\"command\":\"npx\",\"env\":{\"GITHUB_PERSONAL_ACCESS_TOKEN\":\"${GITHUB_PERSONAL_ACCESS_TOKEN}\"}},\"gitlab\":{\"args\":[\"-y\",\"@modelcontextprotocol/server-gitlab\"],\"command\":\"npx\",\"env\":{\"GITLAB_API_URL\":\"http://192.168.50.215:8929/api/v4\",\"GITLAB_PERSONAL_ACCESS_TOKEN\":\"${GITLAB_PERSONAL_ACCESS_TOKEN}\"}},\"kratos\":{\"args\":[\"-y\",\"kratos-mcp\"],\"command\":\"npx\"},\"n8n\":{\"type\":\"streamable-http\",\"url\":\"http://192.168.50.110:5678/mcp-server/http\"},\"onepassword\":{\"args\":[\"/app/op-mcp-server/index.mjs\"],\"command\":\"node\",\"env\":{\"OP_SERVICE_ACCOUNT_TOKEN\":\"${OP_SERVICE_ACCOUNT_TOKEN}\"}},\"playwright\":{\"type\":\"sse\",\"url\":\"http://mcp-playwright:8056/sse\"},\"proxmox\":{\"tools\":{\"proxmox_acl\":{\"enabled\":false},\"proxmox_acme_account\":{\"enabled\":false},\"proxmox_acme_cert\":{\"enabled\":false},\"proxmox_acme_info\":{\"enabled\":false},\"proxmox_agent_freeze\":{\"enabled\":false},\"proxmox_agent_hw\":{\"enabled\":false},\"proxmox_agent_power\":{\"enabled\":false},\"proxmox_agent_user\":{\"enabled\":false},\"proxmox_apt\":{\"enabled\":false},\"proxmox_ceph\":{\"enabled\":false},\"proxmox_ceph_fs\":{\"enabled\":false},\"proxmox_ceph_mds\":{\"enabled\":false},\"proxmox_ceph_mon\":{\"enabled\":false},\"proxmox_ceph_osd\":{\"enabled\":false},\"proxmox_ceph_pool\":{\"enabled\":false},\"proxmox_certificate\":{\"enabled\":false},\"proxmox_cloudinit\":{\"enabled\":false},\"proxmox_cluster_backup_job\":{\"enabled\":false},\"proxmox_cluster_config\":{\"enabled\":false},\"proxmox_cluster_firewall\":{\"enabled\":false},\"proxmox_cluster_firewall_alias\":{\"enabled\":false},\"proxmox_cluster_firewall_group\":{\"enabled\":false},\"proxmox_cluster_firewall_ipset\":{\"enabled\":false},\"proxmox_cluster_firewall_ipset_entry\":{\"enabled\":false},\"proxmox_cluster_firewall_rule\":{\"enabled\":false},\"proxmox_cluster_replication_job\":{\"enabled\":false},\"proxmox_console_spice\":{\"enabled\":false},\"proxmox_console_term\":{\"enabled\":false},\"proxmox_console_vnc\":{\"enabled\":false},\"proxmox_domain\":{\"enabled\":false},\"proxmox_file_restore\":{\"enabled\":false},\"proxmox_group\":{\"enabled\":false},\"proxmox_guest_clone\":{\"enabled\":false},\"proxmox_guest_delete\":{\"enabled\":false},\"proxmox_guest_disk_move\":{\"enabled\":false},\"proxmox_guest_firewall_rule\":{\"enabled\":false},\"proxmox_guest_pause\":{\"enabled\":false},\"proxmox_guest_resume\":{\"enabled\":false},\"proxmox_guest_template\":{\"enabled\":false},\"proxmox_ha_group\":{\"enabled\":false},\"proxmox_ha_resource\":{\"enabled\":false},\"proxmox_lxc_mountpoint\":{\"enabled\":false},\"proxmox_node_bulk\":{\"enabled\":false},\"proxmox_node_disk_admin\":{\"enabled\":false},\"proxmox_node_power\":{\"enabled\":false},\"proxmox_node_replication\":{\"enabled\":false},\"proxmox_node_subscription\":{\"enabled\":false},\"proxmox_notification\":{\"enabled\":false},\"proxmox_pool\":{\"enabled\":false},\"proxmox_role\":{\"enabled\":false},\"proxmox_sdn_controller\":{\"enabled\":false},\"proxmox_sdn_subnet\":{\"enabled\":false},\"proxmox_sdn_vnet\":{\"enabled\":false},\"proxmox_sdn_zone\":{\"enabled\":false},\"proxmox_user\":{\"enabled\":false},\"proxmox_user_token\":{\"enabled\":false},\"proxmox_vm_disk\":{\"enabled\":false}},\"type\":\"sse\",\"url\":\"http://mcp-proxmox:8055/sse\"},\"supabase\":{\"args\":[\"-y\",\"@supabase/mcp-server-supabase\"],\"command\":\"npx\",\"env\":{\"SUPABASE_ACCESS_TOKEN\":\"${SUPABASE_ACCESS_TOKEN}\"}},\"terraform\":{\"args\":[\"-y\",\"terraform-mcp-server\"],\"command\":\"npx\"}}}\n",
