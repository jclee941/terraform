        {
          "index_key": "elk-setup-ilm.sh",
          "schema_version": 0,
          "attributes": {
            "content": "#!/usr/bin/env bash\n# Managed by Terraform — do not edit manually\n# Sets up tiered ILM policies and index templates for log retention\n#\n# Tiers:\n#   critical  (90d) — core infrastructure: elk, supabase, grafana\n#   standard  (30d) — application services: traefik, archon, mcphub, glitchtip, runner\n#   ephemeral  (7d) — debug, unknown, temporary\nset -euo pipefail\n\nES_HOST=\"http://localhost:9200\"\nES_AUTH=\"elastic:I93bmZ/uT3haNpdL9GJ+neTf\"\n\necho \"Waiting for Elasticsearch...\"\nuntil curl -sf -u \"${ES_AUTH}\" \"${ES_HOST}/_cluster/health\" \u003e /dev/null 2\u003e\u00261; do\n  sleep 5\ndone\necho \"Elasticsearch is ready.\"\n\n# —— ILM Policies ————————————————————————————————————————————————\n\ncreate_ilm_policy() {\n  local name=\"$1\" delete_after=\"$2\"\n  echo \"Creating ILM policy: ${name} (delete after ${delete_after})\"\n  curl -sf -u \"${ES_AUTH}\" -X PUT \"${ES_HOST}/_ilm/policy/${name}\" \\\n    -H 'Content-Type: application/json' \\\n    -d '{\n    \"policy\": {\n      \"phases\": {\n        \"hot\": {\n          \"min_age\": \"0ms\",\n          \"actions\": {\n            \"set_priority\": { \"priority\": 100 }\n          }\n        },\n        \"delete\": {\n          \"min_age\": \"'\"${delete_after}\"'\",\n          \"actions\": {\n            \"delete\": {}\n          }\n        }\n      }\n    }\n  }'\n  echo\n}\n\ncreate_ilm_policy \"homelab-logs-critical-90d\"  \"90d\"\ncreate_ilm_policy \"homelab-logs-30d\"           \"30d\"\ncreate_ilm_policy \"homelab-logs-ephemeral-7d\"  \"7d\"\n\n# —— Index Templates —————————————————————————————————————————————\n# Priority determines which template wins when multiple patterns match.\n# Higher priority = takes precedence.\n#   critical  (300) — specific critical service patterns\n#   ephemeral (250) — specific ephemeral patterns\n#   standard  (200) — catch-all logs-* (default tier)\n\ncreate_index_template() {\n  local name=\"$1\" policy=\"$2\" priority=\"$3\"\n  shift 3\n  # Remaining args are index patterns\n  local patterns\n  patterns=$(printf '\"%s\",' \"$@\")\n  patterns=\"[${patterns%,}]\"\n\n  echo \"Creating index template: ${name} (policy=${policy}, priority=${priority})\"\n  curl -sf -u \"${ES_AUTH}\" -X PUT \"${ES_HOST}/_index_template/${name}\" \\\n    -H 'Content-Type: application/json' \\\n    -d '{\n    \"index_patterns\": '\"${patterns}\"',\n    \"priority\": '\"${priority}\"',\n    \"template\": {\n      \"settings\": {\n        \"number_of_shards\": 1,\n        \"number_of_replicas\": 0,\n        \"index.lifecycle.name\": \"'\"${policy}\"'\"\n      }\n    }\n  }'\n  echo\n}\n\n# Critical tier: core infrastructure services (90d retention)\ncreate_index_template \"logs-critical\" \"homelab-logs-critical-90d\" 300 \\\n  \"logs-elk-*\" \"logs-supabase-*\" \"logs-grafana-*\"\n\n# Ephemeral tier: debug and unknown sources (7d retention)\ncreate_index_template \"logs-ephemeral\" \"homelab-logs-ephemeral-7d\" 250 \\\n  \"logs-unknown-*\" \"logs-debug-*\"\n\n# Standard tier: catch-all for remaining services (30d retention)\ncreate_index_template \"logs-standard\" \"homelab-logs-30d\" 200 \\\n  \"logs-*\"\n\necho \"ILM setup complete. Three tiers configured:\"\necho \"  critical  (90d): elk, supabase, grafana\"\necho \"  standard  (30d): all other services (default)\"\necho \"  ephemeral  (7d): unknown, debug\"\n",
            "content_base64": null,
            "content_base64sha256": "3cfYlzHP+zaZfQK4JAUZgi3ARJIJNJdZ2WSU6PJgklY=",
            "content_base64sha512": "ionEaY4P6jkfSuxRGv9qgLk68DFx+mxyA9by4cXjPQjNkpZLOIhCKIN/mMwDKR68TcvpBhpvemKUChywQJh8jQ==",
            "content_md5": "4c374de6a3d94178289fc60df156f33f",
            "content_sha1": "6069d1255b2add76e164d6d1efc0d59fb40d7555",
            "content_sha256": "ddc7d89731cffb36997d02b8240519822dc0449209349759d96494e8f2609256",
            "content_sha512": "8a89c4698e0fea391f4aec511aff6a80b93af03171fa6c7203d6f2e1c5e33d08cd92964b38884228837f98cc03291ebc4dcbe9061a6f7a62940a1cb040987c8d",
            "directory_permission": "0700",
