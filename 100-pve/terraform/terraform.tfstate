        {
          "index_key": "n8n_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 110-n8n (Workflow Automation)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs (n8n, n8n-postgres, n8n-cadvisor, n8n-postgres-exporter)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: n8n\n      host_role: n8n\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: system\n      host_role: n8n\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "WGJ+mjePvcfUQZ2aNjUyOx4lP5FUtwIEuJ3WFeHh33M=",
            "content_base64sha512": "NKOuDf0iXqCOtoy+kJDABrxXgiczTYPzw2ndr9vJilQ0+Ro8xADVEhLlCXdEcDWEU913jGRXIM7ezkBqtMOxlg==",
            "content_md5": "c46017e68c862617d179f317718f27a1",
            "content_sha1": "572ade4f7174563730f96b881528a2cf0f79e0a7",
            "content_sha256": "58627e9a378fbdc7d4419d9a3635323b1e253f9154b70204b89dd615e1e1df73",
