        {
          "index_key": "grafana_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 104-grafana (Observability Stack)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs (prometheus, grafana, tempo, blackbox-exporter)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: grafana\n      host_role: grafana\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: system\n      host_role: grafana\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "Bayj1jsRD3mAfb+RsIjCa82tALHTpv6ANHWbqJnKzTk=",
            "content_base64sha512": "6YVP+Swv4up9oB1Ih1fDJlwB9JLiiBP7XmgLo6+pgZlETuUVtXe3Y58FJ5GvmDCGOt6uWyKmryQMHM1oirxcAQ==",
            "content_md5": "dd5fc8b6e6d2448180410dd7573667d3",
            "content_sha1": "8ce9d6d6b9bffe9da966d1b88b5e96a64203e2ed",
            "content_sha256": "05aca3d63b110f79807dbf91b088c26bcdad00b1d3a6fe8034759ba899cacd39",
