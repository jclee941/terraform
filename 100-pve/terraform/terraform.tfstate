        {
          "index_key": "traefik_elk",
          "schema_version": 0,
          "attributes": {
            "content": "http:\n  routers:\n    kibana:\n      rule: Host(`elk.jclee.me`) || Host(`kibana.jclee.me`)\n      entryPoints:\n        - websecure\n      service: kibana\n      middlewares:\n        - rate-limit-standard@file\n        - chain-basic-auth@file\n      tls:\n        certResolver: cf\n      priority: 10\n\n    kibana-http:\n      rule: Host(`elk.jclee.me`) || Host(`kibana.jclee.me`)\n      entryPoints:\n        - web\n      service: kibana\n      priority: 10\n\n    elasticsearch:\n      rule: Host(`es.jclee.me`)\n      entryPoints:\n        - websecure\n      service: elasticsearch\n      middlewares:\n        - elk-ipallowlist\n        - rate-limit-api@file\n      tls:\n        certResolver: cf\n      priority: 10\n\n    elasticsearch-http:\n      rule: Host(`es.jclee.me`)\n      entryPoints:\n        - web\n      service: elasticsearch\n      middlewares:\n        - elk-ipallowlist\n      priority: 10\n\n  middlewares:\n    elk-ipallowlist:\n      ipAllowList:\n        sourceRange:\n          - \"192.168.50.0/24\"\n          - \"127.0.0.1/32\"\n\n  services:\n    kibana:\n      loadBalancer:\n        servers:\n          - url: http://192.168.50.105:5601\n\n    elasticsearch:\n      loadBalancer:\n        servers:\n          - url: http://192.168.50.105:9200\n",
            "content_base64": null,
