        {
          "index_key": "youtube_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 220-youtube (YouTube Media Server)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs (media services, watchtower)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: youtube\n      host_role: youtube\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: youtube\n      host_role: youtube\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "euSbL4BPBEdOo+vTU1rmgTw1qLHxbob7akpYp4LFL7Y=",
            "content_base64sha512": "zVH7qIaVsETh7qN3M0kKU9EK4qXJ4G1MlcqfqUEmDTHxQd0IOq8XXjCzp29CMWaHpP/Xd9WYtlToKI+1SZmliw==",
            "content_md5": "e4f43da9ae5ce8dd69686ee4275db5d0",
