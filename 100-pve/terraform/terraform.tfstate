        {
          "index_key": "elk-logstash.conf",
          "schema_version": 0,
          "attributes": {
            "content": "input {\n  beats {\n    port =\u003e 5044\n  }\n\n  syslog {\n    port =\u003e 5000\n    type =\u003e \"syslog\"\n  }\n\n  http {\n    port  =\u003e 8080\n    type  =\u003e \"logpush\"\n    codec =\u003e json_lines\n  }\n}\n\nfilter {\n  # Filebeat 8.x container input puts log text in [event][original], not [message].\n  # Copy it to [message] so downstream grok/json filters work correctly.\n  if ![message] and [event][original] {\n    mutate {\n      copy =\u003e { \"[event][original]\" =\u003e \"message\" }\n    }\n  }\n\n  # Extract host metadata from Filebeat fields\n  if [host][name] and ![host_name] {\n    mutate {\n      add_field =\u003e { \"host_name\" =\u003e \"%{[host][name]}\" }\n    }\n  }\n  if [container][name] and ![container_name] {\n    mutate {\n      add_field =\u003e { \"container_name\" =\u003e \"%{[container][name]}\" }\n    }\n  }\n\n  # Truncate oversized messages to prevent OOM (Defense in depth)\n  if [message] {\n    truncate {\n      length_bytes =\u003e 999999\n      add_tag =\u003e [\"truncated\"]\n    }\n  }\n\n  # Extract service name from filebeat fields\n  if [fields][service] {\n    mutate {\n      add_field =\u003e { \"service\" =\u003e \"%{[fields][service]}\" }\n    }\n  }\n\n  # Fallback service extraction from Docker Compose label when filebeat fields are absent.\n  if ![service] and [container][labels][com_docker_compose_service] {\n    mutate {\n      add_field =\u003e { \"service\" =\u003e \"%{[container][labels][com_docker_compose_service]}\" }\n    }\n  }\n\n  # Strip ANSI color/control sequences so term queries and aggregations stay clean.\n  if [message] {\n    mutate {\n      gsub =\u003e [\n        \"message\", \"\\x1B\\[[0-9;]*[A-Za-z]\", \"\"\n      ]\n    }\n  }\n  if [event][original] {\n    mutate {\n      gsub =\u003e [\n        \"[event][original]\", \"\\x1B\\[[0-9;]*[A-Za-z]\", \"\"\n      ]\n    }\n  }\n\n  # Syslog parsing\n  if [type] == \"syslog\" {\n    grok {\n      match =\u003e { \"message\" =\u003e \"%{SYSLOGTIMESTAMP:syslog_timestamp} %{SYSLOGHOST:syslog_hostname} %{DATA:syslog_program}(?:\\\\[%{POSINT:syslog_pid}\\\\])?: %{GREEDYDATA:syslog_message}\" }\n      tag_on_failure =\u003e []\n    }\n    date {\n      match =\u003e [ \"syslog_timestamp\", \"MMM  d HH:mm:ss\", \"MMM dd HH:mm:ss\" ]\n    }\n  }\n  # Synology NAS syslog source identification\n  # Synology sends logs via DSM Log Center to Logstash syslog input (port 5000).\n  if [type] == \"syslog\" {\n    # Remove ECS service object set by syslog input plugin to avoid array collision\n    mutate { remove_field =\u003e [ \"service\" ] }\n    if [host][hostname] =~ /(?i)^(synology|ds920|diskstation)/ {\n      mutate {\n        add_field =\u003e { \"service\" =\u003e \"synology\" }\n      }\n    } else {\n      mutate {\n        add_field =\u003e { \"service\" =\u003e \"syslog\" }\n      }\n    }\n  }\n\n  # Cloudflare Workers Trace Events (Logpush → HTTP input)\n  if [type] == \"logpush\" {\n    mutate {\n      add_field =\u003e { \"service\" =\u003e \"cloudflare-workers\" }\n    }\n    if [ScriptName] {\n      mutate { add_field =\u003e { \"worker_script\" =\u003e \"%{[ScriptName]}\" } }\n    }\n    if [Outcome] and [Outcome] != \"ok\" {\n      mutate {\n        add_field =\u003e {\n          \"level\" =\u003e \"error\"\n          \"tier\" =\u003e \"2\"\n          \"error_classification\" =\u003e \"WORKER_FAILURE\"\n          \"error_severity\" =\u003e \"high\"\n        }\n      }\n    } else {\n      mutate { add_field =\u003e { \"level\" =\u003e \"info\" } }\n    }\n  }\n\n  # JSON log parsing (structured logs from apps)\n  if [message] =~ /^\\s*\\{/ {\n    json {\n      source =\u003e \"message\"\n      target =\u003e \"parsed\"\n      skip_on_invalid_json =\u003e true\n    }\n    if [parsed] {\n      if [parsed][level] {\n        mutate { add_field =\u003e { \"level\" =\u003e \"%{[parsed][level]}\" } }\n      }\n      if [parsed][msg] {\n        mutate { add_field =\u003e { \"log_message\" =\u003e \"%{[parsed][msg]}\" } }\n      } else if [parsed][message] {\n        mutate { add_field =\u003e { \"log_message\" =\u003e \"%{[parsed][message]}\" } }\n      }\n      if [parsed][error] {\n        mutate { add_field =\u003e { \"error_message\" =\u003e \"%{[parsed][error]}\" } }\n      }\n      if [parsed][service] and ![service] {\n        mutate { add_field =\u003e { \"service\" =\u003e \"%{[parsed][service]}\" } }\n      }\n    }\n  }\n\n  # Normalize log level to lowercase\n  if [level] {\n    mutate { lowercase =\u003e [ \"level\" ] }\n  }\n\n  # Extract level from unstructured messages if not already set\n  if ![level] {\n    grok {\n      match =\u003e { \"message\" =\u003e \"(?i)(?\u003clevel\u003efatal|panic|error|warn(?:ing)?|info|debug|trace)\" }\n      tag_on_failure =\u003e []\n    }\n    if [level] {\n      mutate { lowercase =\u003e [ \"level\" ] }\n      # Normalize common level aliases\n      if [level] == \"warning\" {\n        mutate { replace =\u003e { \"level\" =\u003e \"warn\" } }\n      } else if [level] == \"err\" {\n        mutate { replace =\u003e { \"level\" =\u003e \"error\" } }\n      } else if [level] in [\"crit\", \"critical\"] {\n        mutate { replace =\u003e { \"level\" =\u003e \"fatal\" } }\n      }\n    }\n  }\n\n  # Default level if still not set\n  if ![level] {\n    mutate { add_field =\u003e { \"level\" =\u003e \"info\" } }\n  }\n\n  # Error Classification: assign tier and error_code\n  # Tier 1 (Critical): System-level failures\n  # Tier 2 (High):     Service degradation, connectivity issues\n  # Tier 3 (Medium):   Application errors, handled failures\n  # Tier 4 (Low):      Warnings, deprecations\n  if ([message] =~ /(?i)(MCP error -32601: Method not found)/ and [message] =~ /(?i)(failed to get prompts)/) or [message] =~ /(?i)(failed to get prompt from MCP server)/ {\n    mutate {\n      add_field =\u003e {\n        \"tier\" =\u003e \"4\"\n        \"error_classification\" =\u003e \"MCP_OPTIONAL_ENDPOINT\"\n        \"error_severity\" =\u003e \"low\"\n      }\n    }\n  } else if [level] in [\"fatal\", \"panic\"] {\n    mutate {\n      add_field =\u003e {\n        \"tier\" =\u003e \"1\"\n        \"error_classification\" =\u003e \"CRITICAL_FAILURE\"\n        \"error_severity\" =\u003e \"critical\"\n      }\n    }\n  } else if [level] == \"error\" {\n    # OpenCode runtime: expected cancellations and transient conditions.\n    if [message] =~ /(?i)(service=session\\.processor error=The operation was aborted\\.|session\\.prompt .* cancel)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"SESSION_CANCELLED\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    } else if [message] =~ /(?i)(service=session\\.processor error=Rate limit exceeded\\. Please try again later\\.)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"RATE_LIMIT_TRANSIENT\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    } else if [message] =~ /(?i)(MCP error -32602|invalid arguments for (tool|prompt)|structured content does not match the tool's output schema)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"MCP_CLIENT_REQUEST_ERROR\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    } else if [message] =~ /(?i)(requestBodyValues|system\\\":\\[\\{\\\"type\\\":\\\"text\\\")/ and [message] =~ /(?i)(SSE error: Unable to connect|ECONNREFUSED|ETIMEDOUT|ENOTFOUND)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"PAYLOAD_ARTIFACT\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    } else if [message] =~ /(?i)(out of memory|oom|disk full|no space|segfault|core dump)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"1\"\n          \"error_classification\" =\u003e \"RESOURCE_EXHAUSTION\"\n          \"error_severity\" =\u003e \"critical\"\n        }\n      }\n    } else if [message] =~ /(?i)(connection refused|timeout|unreachable|dns|ECONNREFUSED|ETIMEDOUT)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"2\"\n          \"error_classification\" =\u003e \"CONNECTIVITY_FAILURE\"\n          \"error_severity\" =\u003e \"high\"\n        }\n      }\n    } else if [message] =~ /(?i)(502|503|504|bad gateway|service unavailable)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"2\"\n          \"error_classification\" =\u003e \"GATEWAY_ERROR\"\n          \"error_severity\" =\u003e \"high\"\n        }\n      }\n    } else if [message] =~ /(?i)(auth|unauthorized|forbidden|401|403|permission denied)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"3\"\n          \"error_classification\" =\u003e \"AUTH_FAILURE\"\n          \"error_severity\" =\u003e \"medium\"\n        }\n      }\n    } else if [message] =~ /(?i)(null|undefined|NaN|type.*error|cast|parse|syntax|JSON)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"3\"\n          \"error_classification\" =\u003e \"DATA_ERROR\"\n          \"error_severity\" =\u003e \"medium\"\n        }\n      }\n    } else {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"3\"\n          \"error_classification\" =\u003e \"APPLICATION_ERROR\"\n          \"error_severity\" =\u003e \"medium\"\n        }\n      }\n    }\n  } else if [level] == \"warn\" {\n    if [message] =~ /(?i)(deprecated|deprecation|will be removed|end of life)/ {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"DEPRECATION\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    } else {\n      mutate {\n        add_field =\u003e {\n          \"tier\" =\u003e \"4\"\n          \"error_classification\" =\u003e \"WARNING\"\n          \"error_severity\" =\u003e \"low\"\n        }\n      }\n    }\n  }\n\n  # Default tier/classification for non-error events (required for Prometheus labels)\n  if ![tier] {\n    mutate { add_field =\u003e { \"tier\" =\u003e \"0\" \"error_classification\" =\u003e \"NONE\" } }\n  }\n  # Set default service if not set\n  if ![service] {\n    mutate { add_field =\u003e { \"service\" =\u003e \"unknown\" } }\n  }\n\n  # Remove problematic OCI container labels that cause date parsing failures\n  # Docker sends empty strings for these fields but ES maps them as dates\n  mutate {\n    remove_field =\u003e [\n      \"[container][labels][org_opencontainers_image_created]\",\n      \"[container][labels][org_opencontainers_image_revision]\",\n      \"[container][labels][org_opencontainers_image_version]\"\n    ]\n  }\n\n  # Clean up parsed temp field\n  mutate {\n    remove_field =\u003e [ \"parsed\" ]\n  }\n}\n\noutput {\n  elasticsearch {\n    hosts =\u003e [\"elasticsearch:9200\"]\n    user =\u003e \"elastic\"\n    password =\u003e \"I93bmZ/uT3haNpdL9GJ+neTf\"\n    index =\u003e \"logs-%{[service]}-%{+YYYY.MM.dd}\"\n    retry_on_conflict =\u003e 3\n    retry_initial_interval =\u003e 2\n    retry_max_interval =\u003e 64\n  }\n\n  # Dead letter queue - capture failed events\n  if \"_elasticsearch_lookup_failure\" in [tags] or \"_grokparsefailure\" in [tags] {\n    file {\n      path =\u003e \"/usr/share/logstash/dlq/failed-%{+YYYY-MM-dd}.json\"\n      codec =\u003e json_lines\n    }\n  }\n\n\n  # Prometheus metrics for Grafana monitoring\n  # NOTE: logstash-output-prometheus v0.1.3 crashes in LXC/JRuby environments\n  # (jnr.netdb.Protocol.getProtocolByNumber stack trace from WEBrick).\n  # Correct syntax preserved below for reference. Consider logstash-exporter\n  # sidecar container as an alternative when Prometheus metrics are needed.\n  #\n  # prometheus {\n  #   port =\u003e 9198\n  #   increment =\u003e {\n  #     \"logstash_events_in_total\" =\u003e {\n  #       description =\u003e \"Total events processed by Logstash\"\n  #       type =\u003e \"counter\"\n  #       labels =\u003e {\n  #         service =\u003e \"%{[service]}\"\n  #         level =\u003e \"%{[level]}\"\n  #         host_name =\u003e \"%{[host_name]}\"\n  #       }\n  #     }\n  #     \"logstash_errors_total\" =\u003e {\n  #       description =\u003e \"Total error-level events by classification\"\n  #       type =\u003e \"counter\"\n  #       labels =\u003e {\n  #         service =\u003e \"%{[service]}\"\n  #         tier =\u003e \"%{[tier]}\"\n  #         error_classification =\u003e \"%{[error_classification]}\"\n  #       }\n  #     }\n  #   }\n  # }\n}\n",
            "content_base64": null,
            "content_base64sha256": "vFS/ZEjbbgIbyovRPlzB2gxNydyX2JHDCnPHRjpf18M=",
            "content_base64sha512": "ob01tH7l2MvePmClJI8w7gU9DQp74ZuxDTm37xdDeJTK5kKRY3VksgHA3mz1QR9RJ9pm5+gydJKIfPggKm1CeA==",
