        {
          "index_key": "traefik-traefik.yml",
          "schema_version": 0,
          "attributes": {
            "content": "api:\n  dashboard: true\n  insecure: true\n\nmetrics:\n  prometheus:\n    addEntryPointsLabels: true\n    addRoutersLabels: true\n    addServicesLabels: true\n\nentryPoints:\n  web:\n    address: \":80\"\n    http:\n      redirections:\n        entryPoint:\n          to: websecure\n          scheme: https\n          permanent: true\n  websecure:\n    address: \":443\"\n    http:\n      middlewares:\n        - security-headers@file\n\nproviders:\n  docker:\n    endpoint: \"unix:///var/run/docker.sock\"\n    exposedByDefault: false\n  file:\n    directory: /etc/traefik/dynamic\n    watch: true\n\ncertificatesResolvers:\n  letsencrypt:\n    acme:\n      email: jclee@jclee.me\n      storage: /etc/traefik/acme.json\n      httpChallenge:\n        entryPoint: web\n  cf:\n    acme:\n      email: jclee@jclee.me\n      storage: /etc/traefik/acme-cf.json\n      dnsChallenge:\n        provider: cloudflare\n        resolvers:\n          - \"1.1.1.1:53\"\n          - \"8.8.8.8:53\"\n",
            "content_base64": null,
            "content_base64sha256": "o+4oXr7Ci0/E8XkMMmwt/valgS5zgMUNx2F1q49ukBU=",
            "content_base64sha512": "TwKB3f1ANhlhB4Shvw37rSAsbFv9udx59TDVw1MkwA3xfy2GIhkED7b9e7haQ+rcBxPienW6KxbwGn9yy/rnuA==",
