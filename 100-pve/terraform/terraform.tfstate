        {
          "index_key": "traefik",
          "schema_version": 0,
          "attributes": {
            "content": "#cloud-config\nhostname: traefik\nmanage_etc_hosts: true\n\npackage_update: true\npackage_upgrade: false\n\npackages:\n  - curl\n  - jq\n  - ca-certificates\n\n\nruncmd:\n  - systemctl enable filebeat || true\n\nfinal_message: \"Cloud-init completed for traefik\"\n",
            "content_base64": null,
