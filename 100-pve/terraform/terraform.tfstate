        {
          "index_key": "archon_env",
          "schema_version": 0,
          "attributes": {
            "content": "# Archon AI - Terraform Rendered Environment Configuration\n# Generated by Terraform. DO NOT EDIT MANUALLY.\n# Template: 108-archon/templates/.env.tftpl\n\n# Supabase Connection (Required)\nSUPABASE_URL=https://placeholder.supabase.local\nSUPABASE_ANON_KEY=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\nOPENAI_API_KEY=placeholder\n\n# Service Ports Configuration\nHOST=0.0.0.0\nARCHON_SERVER_PORT=8181\nARCHON_MCP_PORT=8051\nARCHON_AGENTS_PORT=8052\nARCHON_UI_PORT=3737\nAGENT_WORK_ORDERS_PORT=8053\n\n# Feature Flags\nENABLE_AGENT_WORK_ORDERS=false\nLOG_LEVEL=INFO\nPROD=false\n\n# MCP Server Monitoring (HTTP mode - secure, no Docker socket)\nENABLE_DOCKER_SOCKET_MONITORING=false\nMCP_HEALTH_CHECK_TIMEOUT=5\n\n# Service Discovery (Docker Compose mode for container networking)\nSERVICE_DISCOVERY_MODE=docker_compose\nSTATE_STORAGE_TYPE=file\nFILE_STATE_DIRECTORY=agent-work-orders-state\n",
            "content_base64": null,
