        {
          "index_key": "archon-filebeat.yml",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 108-archon (AI Knowledge Management)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs (archon-server, archon-mcp, archon-ui)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: archon\n      host_role: archon\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: system\n      host_role: archon\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
