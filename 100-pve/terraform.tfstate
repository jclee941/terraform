        {
          "index_key": "supabase",
          "schema_version": 0,
          "attributes": {
            "content": "services:\n  studio:\n    image: supabase/studio:20250224-95cc97d\n    container_name: supabase-studio\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      STUDIO_PG_META_URL: http://meta:8080\n      SUPABASE_URL: http://kong:8000\n      SUPABASE_PUBLIC_URL: http://192.168.50.107:8000\n      SUPABASE_ANON_KEY: eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\n      SUPABASE_SERVICE_ROLE_KEY: eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogInNlcnZpY2Vfcm9sZSIsICJpc3MiOiAic3VwYWJhc2UiLCAiaWF0IjogMTc3MTYwMDgwMCwgImV4cCI6IDIwODY5NjA4MDB9.vLTEQu-8UATji7axVljZzlmPUrbqbFmx7fjXaQc580Y\n    ports:\n      - \"3000:3000\"\n    depends_on:\n      - kong\n      - meta\n      - db\n    networks:\n      - supabase\n\n  kong:\n    image: kong:2.8.1\n    container_name: supabase-kong\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      KONG_DATABASE: \"off\"\n      KONG_DECLARATIVE_CONFIG: /var/lib/kong/kong.yml\n      KONG_DNS_ORDER: LAST,A,CNAME\n      KONG_PLUGINS: request-transformer,cors,key-auth,acl,basic-auth\n      KONG_NGINX_PROXY_PROXY_BUFFER_SIZE: 160k\n      KONG_NGINX_PROXY_PROXY_BUFFERS: 64 160k\n    ports:\n      - \"8000:8000\"\n      - \"8443:8443\"\n    volumes:\n      - ./kong.yml:/var/lib/kong/kong.yml:ro\n    healthcheck:\n      test: [\"CMD\", \"kong\", \"health\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n    depends_on:\n      - auth\n      - rest\n      - realtime\n      - storage\n    networks:\n      - supabase\n\n  auth:\n    image: supabase/gotrue:v2.158.1\n    container_name: supabase-auth\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      GOTRUE_API_HOST: 0.0.0.0\n      GOTRUE_API_PORT: 9999\n      API_EXTERNAL_URL: http://192.168.50.107:8000\n      GOTRUE_SITE_URL: http://supabase.jclee.me\n      GOTRUE_URI_ALLOW_LIST: \"http://localhost:3000,http://192.168.50.107:3000\"\n      GOTRUE_JWT_SECRET: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n      GOTRUE_JWT_AUD: authenticated\n      GOTRUE_DB_DRIVER: postgres\n      GOTRUE_DB_DATABASE_URL: postgres://supabase_admin:xaBI7AtdjCSRXO/B4JzKRzTw@db:5432/postgres\n      GOTRUE_EXTERNAL_EMAIL_ENABLED: \"true\"\n      GOTRUE_MAILER_AUTOCONFIRM: \"true\"\n      GOTRUE_DISABLE_SIGNUP: \"false\"\n    ports:\n      - \"9999:9999\"\n    depends_on:\n      - db\n    networks:\n      - supabase\n\n  rest:\n    image: postgrest/postgrest:v12.2.8\n    container_name: supabase-rest\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      PGRST_DB_URI: postgres://authenticator:xaBI7AtdjCSRXO/B4JzKRzTw@db:5432/postgres\n      PGRST_DB_SCHEMAS: public,storage,graphql_public\n      PGRST_DB_ANON_ROLE: anon\n      PGRST_JWT_SECRET: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n    ports:\n      - \"3001:3000\"\n    depends_on:\n      - db\n    networks:\n      - supabase\n\n  realtime:\n    image: supabase/realtime:v2.34.47\n    container_name: supabase-realtime\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      DB_HOST: db\n      DB_PORT: 5432\n      DB_USER: supabase_admin\n      DB_PASSWORD: xaBI7AtdjCSRXO/B4JzKRzTw\n      DB_NAME: postgres\n      PORT: 4000\n      JWT_SECRET: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n      SECRET_KEY_BASE: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n      APP_NAME: realtime\n      SEED_SELF_HOST: \"true\"\n    ports:\n      - \"4000:4000\"\n    depends_on:\n      - db\n    networks:\n      - supabase\n\n  meta:\n    image: supabase/postgres-meta:v0.84.3\n    container_name: supabase-meta\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      PG_META_PORT: 8080\n      PG_META_DB_HOST: db\n      PG_META_DB_PORT: 5432\n      PG_META_DB_NAME: postgres\n      PG_META_DB_USER: supabase_admin\n      PG_META_DB_PASSWORD: xaBI7AtdjCSRXO/B4JzKRzTw\n    ports:\n      - \"8080:8080\"\n    depends_on:\n      - db\n    networks:\n      - supabase\n\n  storage:\n    image: supabase/storage-api:v1.20.3\n    container_name: supabase-storage\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      ANON_KEY: eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogImFub24iLCAiaXNzIjogInN1cGFiYXNlIiwgImlhdCI6IDE3NzE2MDA4MDAsICJleHAiOiAyMDg2OTYwODAwfQ.TiwflrKfacFVLlR2k7owaIPfJ8C75bwqRXqP0pzJY3o\n      SERVICE_KEY: eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogInNlcnZpY2Vfcm9sZSIsICJpc3MiOiAic3VwYWJhc2UiLCAiaWF0IjogMTc3MTYwMDgwMCwgImV4cCI6IDIwODY5NjA4MDB9.vLTEQu-8UATji7axVljZzlmPUrbqbFmx7fjXaQc580Y\n      POSTGREST_URL: http://rest:3000\n      PGRST_JWT_SECRET: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n      DATABASE_URL: postgres://supabase_storage_admin:xaBI7AtdjCSRXO/B4JzKRzTw@db:5432/postgres\n      FILE_SIZE_LIMIT: 52428800\n      STORAGE_BACKEND: file\n      FILE_STORAGE_BACKEND_PATH: /var/lib/storage\n      REGION: local\n      GLOBAL_S3_BUCKET: supabase-storage\n    ports:\n      - \"5000:5000\"\n    depends_on:\n      - db\n      - rest\n    volumes:\n      - supabase_storage_data:/var/lib/storage\n    networks:\n      - supabase\n\n  db:\n    image: supabase/postgres:15.8.1.049\n    container_name: supabase-db\n    restart: unless-stopped\n    env_file:\n      - .env\n    environment:\n      POSTGRES_PASSWORD: xaBI7AtdjCSRXO/B4JzKRzTw\n      POSTGRES_DB: postgres\n      POSTGRES_USER: supabase_admin\n      JWT_SECRET: cwCVl7uY4WJUyZo/IpYauD9G8kqvbfhbolfNZVQNeME=\n      JWT_EXP: 3600\n    ports:\n      - \"5432:5432\"\n    volumes:\n      - supabase_db_data:/var/lib/postgresql/data\n    healthcheck:\n      test: [\"CMD-SHELL\", \"pg_isready -U supabase_admin -d postgres\"]\n      interval: 10s\n      timeout: 5s\n      retries: 10\n    networks:\n      - supabase\n\nnetworks:\n  supabase:\n    driver: bridge\n\nvolumes:\n  supabase_db_data:\n  supabase_storage_data:\n",
            "content_base64": null,
