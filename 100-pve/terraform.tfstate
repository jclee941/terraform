        {
          "index_key": "grafana-grafana-datasources.yml",
          "schema_version": 0,
          "attributes": {
            "content": "apiVersion: 1\n\ndatasources:\n  - name: Prometheus\n    type: prometheus\n    access: proxy\n    url: http://prometheus:9090\n    isDefault: true\n    editable: false\n\n  - name: Elasticsearch\n    type: elasticsearch\n    access: proxy\n    url: http://192.168.50.105:9200\n    database: \"logs-*\"\n    isDefault: false\n    basicAuth: true\n    basicAuthUser: elastic\n    secureJsonData:\n      basicAuthPassword: \"I93bmZ/uT3haNpdL9GJ+neTf\"\n    jsonData:\n      timeField: \"@timestamp\"\n      esVersion: \"8.0.0\"\n      logMessageField: message\n      logLevelField: level\n    editable: false\n",
            "content_base64": null,
