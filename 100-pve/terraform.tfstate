        {
          "index_key": "mcphub_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 112-mcphub (MCP Hub + AI/Tools VM)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs (mcphub, mcp-proxmox, mcp-playwright, n8n, vault)\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: mcphub\n      host_role: mcphub\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    fields:\n      service: system\n      host_role: mcphub\n    fields_under_root: false\n\n  # Auth logs\n  - type: filestream\n    id: auth-logs\n    paths:\n      - /var/log/auth.log\n    fields:\n      service: auth\n      host_role: mcphub\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "9bWgkAQCQ0DlrbByHkXn5aHGIKmMOoWwP5JBhyIXMZ8=",
