        {
          "index_key": "traefik_filebeat",
          "schema_version": 0,
          "attributes": {
            "content": "# Filebeat configuration for 102-traefik (Reverse Proxy)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nfilebeat.autodiscover:\n  providers:\n    - type: docker\n      hints.enabled: true\n\nfilebeat.inputs:\n  # Docker container logs\n  - type: filestream\n    id: docker-containers\n    paths:\n      - /var/lib/docker/containers/*/*.log\n    parsers:\n      - container: {}\n    prospector.scanner.symlinks: true\n    fields:\n      service: traefik\n      host_role: traefik\n    fields_under_root: false\n\n  # System logs\n  - type: filestream\n    id: system-logs\n    paths:\n      - /var/log/*.log\n      - /var/log/syslog\n    exclude_files:\n      - 'traefik.*\\.log'\n    fields:\n      service: system\n      host_role: traefik\n    fields_under_root: false\n\n  # Traefik access logs\n  - type: filestream\n    id: traefik-access-logs\n    paths:\n      - /var/log/traefik-access.log\n    fields:\n      service: traefik-access\n      host_role: traefik\n    fields_under_root: false\n\nprocessors:\n  - add_host_metadata: ~\n  - add_docker_metadata:\n      host: \"unix:///var/run/docker.sock\"\n\noutput.logstash:\n  hosts: [\"192.168.50.105:5044\"]\n\nfilebeat.registry.path: /var/lib/filebeat/registry\nlogging.level: info\nlogging.to_files: true\nlogging.files:\n  path: /var/log/filebeat\n  name: filebeat\n  keepfiles: 7\n\nmax_message_bytes: 999999\n",
            "content_base64": null,
            "content_base64sha256": "CM0Fll6O6cQz110rMNy+bgNUNwpbe6QMI0cF05e7fFE=",
            "content_base64sha512": "iUHIUbGd8U+XgKkpStaLYOBlmLOO3MBbAdtaRKI41gJYnJZWKf6+sNG5CkXeVyD32n1ylJvznZV4k+dAFO0N5A==",
