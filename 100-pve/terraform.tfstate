    {
      "module": "module.vm_config",
      "mode": "managed",
      "type": "local_file",
      "name": "cloud_init",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": "mcphub",
          "schema_version": 0,
          "attributes": {
            "content": "#cloud-config\nhostname: mcphub\nmanage_etc_hosts: true\n\npackage_update: true\npackage_upgrade: false\n\npackages:\n  - qemu-guest-agent\n  - curl\n  - vim\n  - git\n  - htop\n  - docker.io\n  - docker-compose-v2\n\nwrite_files:\n  - path: /opt/mcphub/docker-compose.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      services:\n        mcphub:\n          image: samanhappy/mcphub:0.12.3\n          container_name: mcphub\n          restart: unless-stopped\n          ports:\n            - \"3000:3000\"\n          volumes:\n            - ./mcp_settings.json:/app/mcp_settings.json\n            - mcphub_data:/app/data\n            - npm_cache:/root/.npm\n            - /usr/bin/op:/usr/bin/op:ro\n            - ./op-mcp-server:/app/op-mcp-server:ro\n            - /mnt/oc-dev:/home/jclee/dev:ro\n            - ./.gitconfig:/root/.gitconfig:ro\n            - /mnt/oc-kratos:/root/.kratos\n            - ./slack-users-cache.json:/tmp/slack-users-cache.json\n          env_file:\n            - .env\n          environment:\n            - MCPHUB_PORT=3000\n          healthcheck:\n            test: [\"CMD-SHELL\", \"curl -sf http://localhost:3000/ || exit 1\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 30s\n          depends_on:\n            - mcp-proxmox\n            - mcp-playwright\n      \n        mcp-proxmox:\n          build:\n            context: .\n            dockerfile: Dockerfile.proxmox\n          container_name: mcp-proxmox\n          restart: unless-stopped\n          ports:\n            - \"8055:8055\"\n          env_file:\n            - .env\n          healthcheck:\n            test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8055,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 15s\n      \n        mcp-playwright:\n          build:\n            context: .\n            dockerfile: Dockerfile.playwright\n          container_name: mcp-playwright\n          restart: unless-stopped\n          ports:\n            - \"8056:8056\"\n          env_file:\n            - .env\n          environment:\n            - PLAYWRIGHT_MCP_HEADLESS=true\n          healthcheck:\n            test: [\"CMD-SHELL\", \"node -e \\\"const net=require('net');const s=net.connect(8056,'127.0.0.1');s.on('connect',()=\u003e{s.end();process.exit(0)});s.on('error',()=\u003eprocess.exit(1));setTimeout(()=\u003eprocess.exit(1),3000);\\\"\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 15s\n      \n      volumes:\n        mcphub_data:\n        npm_cache:\n      \n  - path: /opt/mcphub/mcp_settings.json\n    permissions: '0644'\n    owner: root:root\n    content: |\n      {\"mcpServers\":{\"archon\":{\"type\":\"streamable-http\",\"url\":\"http://192.168.50.108:8051/mcp\"},\"elk\":{\"args\":[\"-y\",\"@awesome-ai/elasticsearch-mcp\"],\"command\":\"npx\",\"env\":{\"ES_HOST\":\"${ES_HOST}\",\"ES_PASSWORD\":\"${ES_PASSWORD}\",\"ES_USERNAME\":\"${ES_USERNAME}\"}},\"git\":{\"args\":[\"-y\",\"@mseep/git-mcp-server\"],\"command\":\"npx\"},\"github\":{\"args\":[\"-y\",\"@modelcontextprotocol/server-github\"],\"command\":\"npx\",\"env\":{\"GITHUB_PERSONAL_ACCESS_TOKEN\":\"${GITHUB_PERSONAL_ACCESS_TOKEN}\"}},\"glitchtip\":{\"args\":[\"-y\",\"mcp-glitchtip\"],\"command\":\"npx\",\"env\":{\"GLITCHTIP_BASE_URL\":\"${GLITCHTIP_BASE_URL}\",\"GLITCHTIP_ORGANIZATION\":\"${GLITCHTIP_ORGANIZATION}\",\"GLITCHTIP_TOKEN\":\"${GLITCHTIP_TOKEN}\"}},\"kratos\":{\"args\":[\"-y\",\"kratos-mcp\"],\"command\":\"npx\"},\"onepassword\":{\"args\":[\"/app/op-mcp-server/index.mjs\"],\"command\":\"node\",\"env\":{\"OP_SERVICE_ACCOUNT_TOKEN\":\"${OP_SERVICE_ACCOUNT_TOKEN}\"}},\"playwright\":{\"type\":\"sse\",\"url\":\"http://mcp-playwright:8056/sse\"},\"proxmox\":{\"type\":\"sse\",\"url\":\"http://mcp-proxmox:8055/sse\"},\"slack\":{\"args\":[\"-y\",\"slack-mcp-server@latest\",\"--transport\",\"stdio\"],\"command\":\"npx\",\"env\":{\"SLACK_MCP_ADD_MESSAGE_TOOL\":\"true\",\"SLACK_MCP_CHANNELS_CACHE\":\"/tmp/slack-channels-cache.json\",\"SLACK_MCP_USERS_CACHE\":\"/tmp/slack-users-cache.json\",\"SLACK_MCP_XOXB_TOKEN\":\"${SLACK_MCP_XOXB_TOKEN}\",\"SLACK_MCP_XOXP_TOKEN\":\"${SLACK_MCP_XOXP_TOKEN}\"}},\"supabase\":{\"args\":[\"-y\",\"@supabase/mcp-server-supabase\"],\"command\":\"npx\",\"env\":{\"SUPABASE_ACCESS_TOKEN\":\"${SUPABASE_ACCESS_TOKEN}\"}},\"terraform\":{\"args\":[\"-y\",\"terraform-mcp-server\"],\"command\":\"npx\"}}}\n      \n  - path: /opt/mcphub/Dockerfile.proxmox\n    permissions: '0644'\n    owner: root:root\n    content: |\n      FROM node:22-slim\n      \n      WORKDIR /app\n      RUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends curl \u0026\u0026 rm -rf /var/lib/apt/lists/*\n      RUN npm install -g mcp-proxy@6.4.0\n      RUN npm install --save @bldg-7/proxmox-mcp@latest pino-pretty@latest\n      \n      EXPOSE 8055\n      CMD [\"mcp-proxy\", \"--port\", \"8055\", \"--host\", \"0.0.0.0\", \"--\", \"node\", \"node_modules/@bldg-7/proxmox-mcp/dist/index.js\"]\n      \n  - path: /opt/mcphub/Dockerfile.playwright\n    permissions: '0644'\n    owner: root:root\n    content: |\n      FROM node:22-slim\n      \n      WORKDIR /app\n      RUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends curl \u0026\u0026 rm -rf /var/lib/apt/lists/*\n      RUN npm install -g mcp-proxy@6.4.0\n      RUN npm install --save @playwright/mcp@latest\n      \n      RUN npx playwright install --with-deps chromium chrome\n      \n      ENV PLAYWRIGHT_MCP_HEADLESS=true\n      EXPOSE 8056\n      CMD [\"mcp-proxy\", \"--port\", \"8056\", \"--host\", \"0.0.0.0\", \"--\", \"npx\", \"@playwright/mcp\", \"--no-sandbox\"]\n      \n  - path: /opt/mcphub/.env\n    permissions: '0600'\n    owner: root:root\n    content: |\n      MCPHUB_ADMIN_PASSWORD=c}Tq{lm\u003c]Eu\u003evi)4r={lyaxo\n      N8N_MCP_API_KEY=4IY4uc0ir8ZuSmDJHV2HRvnHEOLxW81swjJ6ZwMj\n      OP_SERVICE_ACCOUNT_TOKEN=ops_\n      GITHUB_PERSONAL_ACCESS_TOKEN=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\n      SUPABASE_ACCESS_TOKEN=eyJhbGciOiAiSFMyNTYiLCAidHlwIjogIkpXVCJ9.eyJyb2xlIjogInNlcnZpY2Vfcm9sZSIsICJpc3MiOiAic3VwYWJhc2UiLCAiaWF0IjogMTc3MTYwMDgwMCwgImV4cCI6IDIwODY5NjA4MDB9.vLTEQu-8UATji7axVljZzlmPUrbqbFmx7fjXaQc580Y\n      GLITCHTIP_TOKEN=4813c494717ae627ad589f17c55a21e30309ec2f5669be37d5b9cd64854bcb10\n      GLITCHTIP_ORGANIZATION=jclee-homelab\n      GLITCHTIP_BASE_URL=http://192.168.50.106:8000\n      ES_HOST=http://192.168.50.105:9200\n      ES_USERNAME=elastic\n      ES_PASSWORD=I93bmZ/uT3haNpdL9GJ+neTf\n      PROXMOX_HOST=192.168.50.100\n      PROXMOX_PORT=8006\n      PROXMOX_SSL_MODE=insecure\n      PROXMOX_USER=root@pam\n      PROXMOX_TOKEN_NAME=terraform-api\n      PROXMOX_TOKEN_VALUE=0d925da9-a02c-427f-b8e9-1ab71c7a5150\n      PROXMOX_ALLOW_ELEVATED=true\n      SLACK_MCP_XOXP_TOKEN=xoxe.xoxp-1-Mi0yLTk5MDY2MjUzMzM1NzQtOTg5MzIyMTEyNzYwNy05OTA4OTkxMzQ0OTQ2LTEwNTY1OTkzODM0MDM4LWU5ZTQ0ZmM0ZDRhYjU0ZDI0NmY4MDBlZThkY2FjN2Y1N2NiOWYyNmIxNDMyM2QyZDRiOTdmYjRmMTY2MTFjNjg\n      SLACK_MCP_XOXB_TOKEN=PLACEHOLDER_NEEDS_REAL_TOKEN\n      \n  - path: /etc/filebeat/filebeat.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      # Filebeat configuration for 112-mcphub (MCP Hub + AI/Tools VM)\n      # Rendered by Terraform - DO NOT EDIT MANUALLY\n      \n      filebeat.autodiscover:\n        providers:\n          - type: docker\n            hints.enabled: true\n      \n      filebeat.inputs:\n        # Docker container logs (mcphub, mcp-proxmox, mcp-playwright, n8n, vault)\n        - type: filestream\n          id: docker-containers\n          paths:\n            - /var/lib/docker/containers/*/*.log\n          parsers:\n            - container: {}\n          prospector.scanner.symlinks: true\n          fields:\n            service: mcphub\n            host_role: mcphub\n          fields_under_root: false\n      \n        # System logs\n        - type: filestream\n          id: system-logs\n          paths:\n            - /var/log/*.log\n            - /var/log/syslog\n          fields:\n            service: system\n            host_role: mcphub\n          fields_under_root: false\n      \n        # Auth logs\n        - type: filestream\n          id: auth-logs\n          paths:\n            - /var/log/auth.log\n          fields:\n            service: auth\n            host_role: mcphub\n          fields_under_root: false\n      \n      processors:\n        - add_host_metadata: ~\n        - add_docker_metadata:\n            host: \"unix:///var/run/docker.sock\"\n      \n      output.logstash:\n        hosts: [\"192.168.50.105:5044\"]\n      \n      filebeat.registry.path: /var/lib/filebeat/registry\n      logging.level: info\n      logging.to_files: true\n      logging.files:\n        path: /var/log/filebeat\n        name: filebeat\n        keepfiles: 7\n      \n      max_message_bytes: 999999\n      \n  - path: /opt/n8n/docker-compose.yml\n    permissions: '0644'\n    owner: root:root\n    content: |\n      services:\n        n8n:\n          container_name: n8n\n          image: n8nio/n8n:2.8.1\n          restart: unless-stopped\n          ports:\n            - \"5678:5678\"\n          environment:\n            N8N_API_KEY: 4IY4uc0ir8ZuSmDJHV2HRvnHEOLxW81swjJ6ZwMj\n            N8N_HOST: n8n.jclee.me\n            N8N_PORT: 5678\n            N8N_PROTOCOL: https\n            N8N_SECURE_COOKIE: \"false\"\n            TZ: Asia/Seoul\n            WEBHOOK_URL: https://n8n.jclee.me/\n            EXECUTIONS_DATA_SAVE_ON_ERROR: \"all\"\n            N8N_EXECUTION_TIMEOUT: \"300\"\n          deploy:\n            resources:\n              limits:\n                memory: 1G\n                cpus: '1.00'\n          logging:\n            driver: json-file\n            options:\n              max-size: \"50m\"\n              max-file: \"5\"\n          healthcheck:\n            test: [\"CMD-SHELL\", \"curl -sf http://localhost:5678/healthz || exit 1\"]\n            interval: 30s\n            timeout: 10s\n            retries: 3\n            start_period: 30s\n          volumes:\n            - n8n_data:/home/node/.n8n\n          networks:\n            - n8n_default\n      \n      volumes:\n        n8n_data:\n          name: n8n_n8n_data\n          driver: local\n      \n      networks:\n        n8n_default:\n          name: n8n_default\n          driver: bridge\n      \n\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - systemctl enable docker\n  - systemctl start docker\n  - mkdir -p /opt/mcphub\n  - mkdir -p /opt/n8n\n  - systemctl daemon-reload\n  - cd /opt/mcphub \u0026\u0026 docker compose build \u0026\u0026 docker compose up -d\n  - cd /opt/n8n \u0026\u0026 docker compose up -d\n\nfinal_message: \"Cloud-init completed for mcphub\"\n",
            "content_base64": null,
            "content_base64sha256": "+TDcQ60AiekpynZwgtxlIJ7Tf7DZvXV5YsAMMInT8u8=",
