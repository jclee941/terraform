          "attributes": {
            "content": "http:\n  routers:\n    nas:\n      rule: \"Host(`nas.jclee.me`)\"\n      entryPoints:\n        - websecure\n      service: nas\n      tls:\n        certResolver: cf\n      priority: 10\n  services:\n    nas:\n      loadBalancer:\n        servers:\n          - url: \"http://192.168.50.215:5000\"\n",
