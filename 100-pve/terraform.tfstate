            "content": "services:\n  op-connect-api:\n    image: 1password/connect-api:latest\n    ports:\n      - \"8090:8080\"\n    volumes:\n      - ./1password-credentials.json:/home/opuser/.op/1password-credentials.json:ro\n      - op-connect-data:/home/opuser/.op/data\n    restart: unless-stopped\n\n  op-connect-sync:\n    image: 1password/connect-sync:latest\n    volumes:\n      - ./1password-credentials.json:/home/opuser/.op/1password-credentials.json:ro\n      - op-connect-data:/home/opuser/.op/data\n    restart: unless-stopped\n\nvolumes:\n  op-connect-data:\n",
