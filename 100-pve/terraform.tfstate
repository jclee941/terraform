          "index_key": "traefik_cloudflared",
          "schema_version": 0,
          "attributes": {
            "content": "# ============================================\n# Cloudflare Tunnel - Homelab Connector\n# ============================================\n# Managed by Terraform (100-pve workspace).\n# Do NOT edit manually.\n#\n# Token source: 300-cloudflare workspace\n#   terraform output -raw homelab_tunnel_token\n# ============================================\n\nservices:\n  cloudflared:\n    image: cloudflare/cloudflared:latest\n    container_name: cloudflared-homelab\n    restart: unless-stopped\n    command: tunnel --no-autoupdate run --token \n    network_mode: host\n    healthcheck:\n      test: [\"CMD\", \"cloudflared\", \"tunnel\", \"info\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 10s\n    logging:\n      driver: json-file\n      options:\n        max-size: \"10m\"\n        max-file: \"3\"\n",
            "content_base64": null,
