        {
          "index_key": "elk_dockerfile_logstash",
          "schema_version": 0,
          "attributes": {
            "content": "FROM docker.elastic.co/logstash/logstash:8.17.0\n\n# Prometheus metrics are exposed via the logstash-exporter sidecar (port 9198).\n# Keep the base image unmodified to avoid JRuby plugin instability in LXC.\n",
            "content_base64": null,
            "content_base64sha256": "ENbnpwVou8sopSFnlYv3pIiqya1lf55Go/RvWy75X68=",
