        {
          "index_key": "glitchtip",
          "schema_version": 0,
          "attributes": {
            "content": "services:\n  web:\n    image: glitchtip/glitchtip:v6.0.5\n    container_name: glitchtip-web\n    env_file:\n      - ./glitchtip.env\n    command: [\"./bin/start.sh\"]\n    environment:\n      SERVER_ROLE: web\n    depends_on:\n      postgres:\n        condition: service_healthy\n      redis:\n        condition: service_healthy\n    ports:\n      - \"8000:8000\"\n    healthcheck:\n      test: [\"CMD-SHELL\", \"python -c 'import urllib.request; urllib.request.urlopen(\\\"http://localhost:8000/_health/\\\")' || exit 1\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 30s\n    restart: unless-stopped\n\n  worker:\n    image: glitchtip/glitchtip:v6.0.5\n    container_name: glitchtip-worker\n    env_file:\n      - ./glitchtip.env\n    command: [\"./bin/start.sh\"]\n    environment:\n      SERVER_ROLE: worker_with_beat\n    depends_on:\n      postgres:\n        condition: service_healthy\n      redis:\n        condition: service_healthy\n    healthcheck:\n      test: [\"CMD-SHELL\", \"celery -A glitchtip inspect ping --timeout 10 || exit 1\"]\n      interval: 60s\n      timeout: 15s\n      retries: 3\n      start_period: 30s\n    restart: unless-stopped\n\n  postgres:\n    image: postgres:15.16-alpine\n    container_name: glitchtip-postgres\n    environment:\n      POSTGRES_DB: glitchtip\n      POSTGRES_USER: glitchtip\n      POSTGRES_PASSWORD: iP67xaGlJjsyayIUneiihyMP\n    volumes:\n      - glitchtip_postgres_data:/var/lib/postgresql/data\n    healthcheck:\n      test: [\"CMD-SHELL\", \"pg_isready -U glitchtip -d glitchtip\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n    restart: unless-stopped\n\n  redis:\n    image: redis:7.4.7-alpine\n    container_name: glitchtip-redis\n    command: [\"redis-server\", \"--requirepass\", \"YNZgMmYlyaoNXjE86s6g0F3K\"]\n    volumes:\n      - glitchtip_redis_data:/data\n    healthcheck:\n      test: [\"CMD\", \"redis-cli\", \"-a\", \"YNZgMmYlyaoNXjE86s6g0F3K\", \"ping\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n    restart: unless-stopped\n\nvolumes:\n  glitchtip_postgres_data:\n    driver: local\n  glitchtip_redis_data:\n    driver: local\n",
