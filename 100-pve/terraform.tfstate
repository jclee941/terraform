        {
          "index_key": "coredns_docker_compose",
          "schema_version": 0,
          "attributes": {
            "content": "# CoreDNS Docker Compose for 103-coredns (Split DNS Resolver)\n# Rendered by Terraform - DO NOT EDIT MANUALLY\n\nservices:\n  coredns:\n    image: coredns/coredns:latest\n    container_name: coredns\n    restart: unless-stopped\n    command: -conf /etc/coredns/Corefile\n    network_mode: host\n    volumes:\n      - /opt/coredns/Corefile:/etc/coredns/Corefile:ro\n    logging:\n      driver: json-file\n      options:\n        max-size: \"10m\"\n        max-file: \"3\"\n",
            "content_base64": null,
