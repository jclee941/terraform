        {
          "index_key": "mcphub_mcp_settings",
          "schema_version": 0,
          "attributes": {
            "content": "{\"mcpServers\":{\"archon\":{\"type\":\"streamable-http\",\"url\":\"http://192.168.50.108:8051/mcp\"},\"elk\":{\"args\":[\"-y\",\"@awesome-ai/elasticsearch-mcp\"],\"command\":\"npx\",\"env\":{\"ES_HOST\":\"${ES_HOST}\",\"ES_PASSWORD\":\"${ES_PASSWORD}\",\"ES_USERNAME\":\"${ES_USERNAME}\"}},\"git\":{\"args\":[\"-y\",\"@mseep/git-mcp-server\"],\"command\":\"npx\"},\"github\":{\"args\":[\"-y\",\"@modelcontextprotocol/server-github\"],\"command\":\"npx\",\"env\":{\"GITHUB_PERSONAL_ACCESS_TOKEN\":\"${GITHUB_PERSONAL_ACCESS_TOKEN}\"}},\"glitchtip\":{\"args\":[\"-y\",\"mcp-glitchtip\"],\"command\":\"npx\",\"env\":{\"GLITCHTIP_BASE_URL\":\"${GLITCHTIP_BASE_URL}\",\"GLITCHTIP_ORGANIZATION\":\"${GLITCHTIP_ORGANIZATION}\",\"GLITCHTIP_TOKEN\":\"${GLITCHTIP_TOKEN}\"}},\"kratos\":{\"args\":[\"-y\",\"kratos-mcp\"],\"command\":\"npx\"},\"onepassword\":{\"args\":[\"/app/op-mcp-server/index.mjs\"],\"command\":\"node\",\"env\":{\"OP_SERVICE_ACCOUNT_TOKEN\":\"${OP_SERVICE_ACCOUNT_TOKEN}\"}},\"playwright\":{\"type\":\"sse\",\"url\":\"http://mcp-playwright:8056/sse\"},\"proxmox\":{\"type\":\"sse\",\"url\":\"http://mcp-proxmox:8055/sse\"},\"slack\":{\"args\":[\"-y\",\"slack-mcp-server@latest\",\"--transport\",\"stdio\"],\"command\":\"npx\",\"env\":{\"SLACK_MCP_ADD_MESSAGE_TOOL\":\"true\",\"SLACK_MCP_CHANNELS_CACHE\":\"/tmp/slack-channels-cache.json\",\"SLACK_MCP_USERS_CACHE\":\"/tmp/slack-users-cache.json\",\"SLACK_MCP_XOXB_TOKEN\":\"${SLACK_MCP_XOXB_TOKEN}\",\"SLACK_MCP_XOXP_TOKEN\":\"${SLACK_MCP_XOXP_TOKEN}\"}},\"supabase\":{\"args\":[\"-y\",\"@supabase/mcp-server-supabase\"],\"command\":\"npx\",\"env\":{\"SUPABASE_ACCESS_TOKEN\":\"${SUPABASE_ACCESS_TOKEN}\"}},\"terraform\":{\"args\":[\"-y\",\"terraform-mcp-server\"],\"command\":\"npx\"}}}\n",
