http:
  routers:
    n8n:
      rule: Host(`n8n.${domain}`)
      entryPoints:
        - websecure
      service: n8n
      middlewares:
        - rate-limit-api@file
      tls:
        certResolver: cf
      priority: 10

    n8n-http:
      rule: Host(`n8n.${domain}`)
      entryPoints:
        - web
      service: n8n
      priority: 10

  services:
    n8n:
      loadBalancer:
        servers:
          - url: http://${hosts.mcphub.ip}:${hosts.mcphub.ports.n8n}
