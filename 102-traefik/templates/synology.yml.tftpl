http:
  routers:
    nas:
      rule: "Host(`nas.${domain}`)"
      entryPoints:
        - websecure
      service: nas
      middlewares:
        - rate-limit-relaxed@file
      tls:
        certResolver: cf
      priority: 10
  services:
    nas:
      loadBalancer:
        servers:
          - url: "http://${hosts.synology.ip}:${hosts.synology.ports.dsm}"
