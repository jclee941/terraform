http:
  routers:
    opencode:
      rule: Host(`opencode.${domain}`)
      entryPoints:
        - websecure
      service: opencode
      middlewares:
        - rate-limit-standard@file
      tls:
        certResolver: cf
      priority: 10

    opencode-http:
      rule: Host(`opencode.${domain}`)
      entryPoints:
        - web
      service: opencode
      priority: 10

  services:
    opencode:
      loadBalancer:
        servers:
          - url: http://${hosts["jclee-dev"].ip}:${hosts["jclee-dev"].ports.opencode}
