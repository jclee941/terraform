          "attributes": {
            "config_json": "{\"__inputs\":[],\"__requires\":[],\"annotations\":{\"list\":[]},\"description\":\"Dedicated monitoring dashboard for Archon (108) (192.168.50.108)\",\"panels\":[{\"collapsed\":false,\"gridPos\":{\"h\":1,\"w\":24,\"x\":0,\"y\":0},\"title\":\"Service Status\",\"type\":\"row\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"mappings\":[{\"options\":{\"0\":{\"color\":\"red\",\"text\":\"DOWN\"},\"1\":{\"color\":\"green\",\"text\":\"UP\"}},\"type\":\"value\"}],\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"red\",\"value\":null},{\"color\":\"green\",\"value\":1}]}},\"overrides\":[]},\"gridPos\":{\"h\":4,\"w\":4,\"x\":0,\"y\":1},\"options\":{\"colorMode\":\"background\",\"graphMode\":\"none\",\"reduceOptions\":{\"calcs\":[\"lastNotNull\"]}},\"targets\":[{\"expr\":\"probe_success{instance=~\\\".*192.168.50.108.*3737.*\\\"}\",\"legendFormat\":\"UI\",\"refId\":\"A\"}],\"title\":\"UI\",\"type\":\"stat\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"green\",\"value\":null},{\"color\":\"yellow\",\"value\":0.5},{\"color\":\"red\",\"value\":2}]},\"unit\":\"s\"},\"overrides\":[]},\"gridPos\":{\"h\":4,\"w\":4,\"x\":4,\"y\":1},\"options\":{\"colorMode\":\"background\",\"graphMode\":\"area\",\"reduceOptions\":{\"calcs\":[\"lastNotNull\"]}},\"targets\":[{\"expr\":\"probe_duration_seconds{instance=~\\\".*192.168.50.108.*\\\"}\",\"legendFormat\":\"Duration\",\"refId\":\"A\"}],\"title\":\"Response Time\",\"type\":\"stat\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"mappings\":[{\"options\":{\"0\":{\"color\":\"red\",\"text\":\"DOWN\"},\"1\":{\"color\":\"green\",\"text\":\"UP\"}},\"type\":\"value\"}],\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"red\",\"value\":null},{\"color\":\"green\",\"value\":1}]}},\"overrides\":[]},\"gridPos\":{\"h\":4,\"w\":4,\"x\":8,\"y\":1},\"options\":{\"colorMode\":\"background\",\"graphMode\":\"none\",\"reduceOptions\":{\"calcs\":[\"lastNotNull\"]}},\"targets\":[{\"expr\":\"up{instance=\\\"192.168.50.108:9100\\\"}\",\"legendFormat\":\"Node Exporter\",\"refId\":\"A\"}],\"title\":\"Host Agent\",\"type\":\"stat\"},{\"collapsed\":false,\"gridPos\":{\"h\":1,\"w\":24,\"x\":0,\"y\":5},\"title\":\"Host Resources\",\"type\":\"row\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"max\":100,\"min\":0,\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"green\",\"value\":null},{\"color\":\"yellow\",\"value\":60},{\"color\":\"red\",\"value\":85}]},\"unit\":\"percent\"},\"overrides\":[]},\"gridPos\":{\"h\":6,\"w\":6,\"x\":0,\"y\":6},\"targets\":[{\"expr\":\"100 - (avg(rate(node_cpu_seconds_total{instance=\\\"192.168.50.108:9100\\\",mode=\\\"idle\\\"}[5m])) * 100)\",\"legendFormat\":\"CPU\",\"refId\":\"A\"}],\"title\":\"CPU Usage\",\"type\":\"gauge\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"max\":100,\"min\":0,\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"green\",\"value\":null},{\"color\":\"yellow\",\"value\":70},{\"color\":\"red\",\"value\":90}]},\"unit\":\"percent\"},\"overrides\":[]},\"gridPos\":{\"h\":6,\"w\":6,\"x\":6,\"y\":6},\"targets\":[{\"expr\":\"(1 - node_memory_MemAvailable_bytes{instance=\\\"192.168.50.108:9100\\\"} / node_memory_MemTotal_bytes{instance=\\\"192.168.50.108:9100\\\"}) * 100\",\"legendFormat\":\"Memory\",\"refId\":\"A\"}],\"title\":\"Memory Usage\",\"type\":\"gauge\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"thresholds\"},\"max\":100,\"min\":0,\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"green\",\"value\":null},{\"color\":\"yellow\",\"value\":70},{\"color\":\"red\",\"value\":90}]},\"unit\":\"percent\"},\"overrides\":[]},\"gridPos\":{\"h\":6,\"w\":6,\"x\":12,\"y\":6},\"targets\":[{\"expr\":\"(1 - node_filesystem_avail_bytes{instance=\\\"192.168.50.108:9100\\\",mountpoint=\\\"/\\\"} / node_filesystem_size_bytes{instance=\\\"192.168.50.108:9100\\\",mountpoint=\\\"/\\\"}) * 100\",\"legendFormat\":\"Disk\",\"refId\":\"A\"}],\"title\":\"Disk Usage (/)\",\"type\":\"gauge\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"fixedColor\":\"blue\",\"mode\":\"fixed\"},\"unit\":\"dtdurations\"},\"overrides\":[]},\"gridPos\":{\"h\":6,\"w\":6,\"x\":18,\"y\":6},\"options\":{\"colorMode\":\"value\",\"graphMode\":\"none\",\"reduceOptions\":{\"calcs\":[\"lastNotNull\"]}},\"targets\":[{\"expr\":\"node_time_seconds{instance=\\\"192.168.50.108:9100\\\"} - node_boot_time_seconds{instance=\\\"192.168.50.108:9100\\\"}\",\"legendFormat\":\"Uptime\",\"refId\":\"A\"}],\"title\":\"Uptime\",\"type\":\"stat\"},{\"collapsed\":false,\"gridPos\":{\"h\":1,\"w\":24,\"x\":0,\"y\":12},\"title\":\"Resource History\",\"type\":\"row\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"palette-classic\"},\"custom\":{\"drawStyle\":\"line\",\"fillOpacity\":15,\"lineWidth\":2,\"showPoints\":\"never\",\"stacking\":{\"mode\":\"none\"}},\"max\":100,\"min\":0,\"unit\":\"percent\"},\"overrides\":[]},\"gridPos\":{\"h\":7,\"w\":12,\"x\":0,\"y\":13},\"options\":{\"legend\":{\"displayMode\":\"list\",\"placement\":\"bottom\"},\"tooltip\":{\"mode\":\"multi\"}},\"targets\":[{\"expr\":\"100 - (avg(rate(node_cpu_seconds_total{instance=\\\"192.168.50.108:9100\\\",mode=\\\"idle\\\"}[5m])) * 100)\",\"legendFormat\":\"CPU %\",\"refId\":\"A\"}],\"title\":\"CPU Usage Over Time\",\"type\":\"timeseries\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"palette-classic\"},\"custom\":{\"drawStyle\":\"line\",\"fillOpacity\":15,\"lineWidth\":2,\"showPoints\":\"never\",\"stacking\":{\"mode\":\"none\"}},\"unit\":\"bytes\"},\"overrides\":[]},\"gridPos\":{\"h\":7,\"w\":12,\"x\":12,\"y\":13},\"options\":{\"legend\":{\"displayMode\":\"list\",\"placement\":\"bottom\"},\"tooltip\":{\"mode\":\"multi\"}},\"targets\":[{\"expr\":\"node_memory_MemTotal_bytes{instance=\\\"192.168.50.108:9100\\\"}\",\"legendFormat\":\"Total\",\"refId\":\"A\"},{\"expr\":\"node_memory_MemTotal_bytes{instance=\\\"192.168.50.108:9100\\\"} - node_memory_MemAvailable_bytes{instance=\\\"192.168.50.108:9100\\\"}\",\"legendFormat\":\"Used\",\"refId\":\"B\"},{\"expr\":\"node_memory_MemAvailable_bytes{instance=\\\"192.168.50.108:9100\\\"}\",\"legendFormat\":\"Available\",\"refId\":\"C\"}],\"title\":\"Memory Usage Over Time\",\"type\":\"timeseries\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"palette-classic\"},\"custom\":{\"drawStyle\":\"line\",\"fillOpacity\":10,\"lineWidth\":2,\"showPoints\":\"never\",\"stacking\":{\"mode\":\"none\"}},\"unit\":\"Bps\"},\"overrides\":[]},\"gridPos\":{\"h\":7,\"w\":12,\"x\":0,\"y\":20},\"options\":{\"legend\":{\"displayMode\":\"list\",\"placement\":\"bottom\"},\"tooltip\":{\"mode\":\"multi\"}},\"targets\":[{\"expr\":\"rate(node_network_receive_bytes_total{instance=\\\"192.168.50.108:9100\\\",device!=\\\"lo\\\"}[5m])\",\"legendFormat\":\"RX {{{{device}}}}\",\"refId\":\"A\"},{\"expr\":\"-rate(node_network_transmit_bytes_total{instance=\\\"192.168.50.108:9100\\\",device!=\\\"lo\\\"}[5m])\",\"legendFormat\":\"TX {{{{device}}}}\",\"refId\":\"B\"}],\"title\":\"Network I/O\",\"type\":\"timeseries\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"palette-classic\"},\"custom\":{\"drawStyle\":\"line\",\"fillOp