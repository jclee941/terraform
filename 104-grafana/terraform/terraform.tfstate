            "name": "infrastructure-health",
            "org_id": "1",
            "rule": [
              {
                "annotations": {
                  "description": "CPU usage above 90% on {{ $labels.instance }} for 10 minutes",
                  "summary": "CPU usage high"
                },
                "condition": "C",
                "data": [
                  {
                    "datasource_uid": "PBFA97CFB590B2093",
                    "model": "{\"expr\":\"100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\\\"idle\\\"}[5m])) * 100)\"}",
                    "query_type": "",
                    "ref_id": "A",
                    "relative_time_range": [
                      {
                        "from": 600,
                        "to": 0
                      }
                    ]
                  },
                  {
                    "datasource_uid": "-100",
                    "model": "{\"conditions\":[{\"evaluator\":{\"params\":[90],\"type\":\"gt\"}}],\"expression\":\"A\",\"type\":\"threshold\"}",
                    "query_type": "",
                    "ref_id": "C",
                    "relative_time_range": [
                      {
                        "from": 0,
                        "to": 0
                      }
                    ]
                  }
                ],
                "exec_err_state": "OK",
                "for": "10m0s",
                "is_paused": false,
                "keep_firing_for": "",
                "labels": {
                  "severity": "warning"
                },
                "missing_series_evals_to_resolve": 0,
                "name": "cpu-usage-high",
                "no_data_state": "OK",
                "notification_settings": [],
                "record": [],
                "uid": "bfdau62mbpslcc"
