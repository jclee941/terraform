                  {
                    "datasource_uid": "P31C819B24CF3C3C7",
                    "model": "{\"bucketAggs\":[{\"field\":\"@timestamp\",\"id\":\"2\",\"settings\":{\"interval\":\"auto\"},\"type\":\"date_histogram\"}],\"metrics\":[{\"id\":\"1\",\"type\":\"count\"}],\"query\":\"host_name:traefik AND message:(400 OR 401 OR 403 OR 404 OR 405 OR 429)\",\"timeField\":\"@timestamp\"}",
