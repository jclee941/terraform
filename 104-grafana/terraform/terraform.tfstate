ode_cpu_seconds_total{mode=\\\"idle\\\", instance=~\\\"192.168.50.100.*\\\"}[5m])) * 100)\",\"legendFormat\":\"CPU {{cpu}}\",\"refId\":\"A\"}],\"title\":\"CPU Usage by Core\",\"type\":\"timeseries\"},{\"collapsed\":false,\"gridPos\":{\"h\":1,\"w\":24,\"x\":0,\"y\":9},\"title\":\"\ud83e\udde0 Memory\",\"type\":\"row\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"description\":\"PVE host memory utilization\",\"fieldConfig\":{\"defaults\":{\"max\":100,\"min\":0,\"thresholds\":{\"mode\":\"absolute\",\"steps\":[{\"color\":\"green\",\"value\":null},{\"color\":\"yellow\",\"value\":75},{\"color\":\"red\",\"value\":90}]},\"unit\":\"percent\"},\"overrides\":[]},\"gridPos\":{\"h\":6,\"w\":8,\"x\":0,\"y\":10},\"options\":{\"orientation\":\"auto\",\"reduceOptions\":{\"calcs\":[\"lastNotNull\"]},\"showThresholdLabels\":false,\"showThresholdMarkers\":true},\"targets\":[{\"expr\":\"(1 - node_memory_MemAvailable_bytes{instance=~\\\"192.168.50.100.*\\\"} / node_memory_MemTotal_bytes{instance=~\\\"192.168.50.100.*\\\"}) * 100\",\"legendFormat\":\"Memory Usage\",\"refId\":\"A\"}],\"title\":\"PVE Memory Usage\",\"type\":\"gauge\"},{\"datasource\":{\"type\":\"prometheus\",\"uid\":\"prometheus\"},\"description\":\"Memory usage breakdown over time\",\"fieldConfig\":{\"defaults\":{\"color\":{\"mode\":\"palette-classic\"},\"custom\":{\"fillOpacity\":30,\"lineWidth\":1,\"spanNulls\":false,\"stacking\":{\"mode\":\"normal\"}},\"unit\":\"bytes\"},\"overrides\":[]},\"gridPos\":{\"h\":8,\"w\":16,\"x\":8,\"y\":10},\"options\":{\"legend\":{\"calcs\":[\"lastNotNull\"],\"displayMode\":\"table\",\"placement\":\"right\"},\"tooltip\":{\"mode\":\"multi\",\"sort\":\"desc\"}},\"targets\":[{\"expr\":\"node_memory_MemTotal_bytes{instance=~\\\"192.168.50.100.*\\\"} - node_memory_MemAvailable_bytes{instance=~\\\"192.168.50.100.*\\\"}\",\"legendFormat\":\"Used\",\"refId\":\"A\"},{\"expr\":\"node_memory_Buffers_bytes{instance=~\\\"192.168.50.100.*\\\"}\",\"legendFormat\":\"Buffers\",\"refId