  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["homelab", "services", "health", "traefik"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Service Health Dashboard",
  "uid": "service-health"
