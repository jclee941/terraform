      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "targets": [
        {
          "alias": "{{level.keyword}}",
          "bucketAggs": [
            {
              "field": "level.keyword",
              "id": "3",
              "settings": {
                "min_doc_count": "1",
                "order": "desc",
                "orderBy": "_count",
                "size": "10"
              },
              "type": "terms"
            },
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "*",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Log Level Distribution Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Log volume per service host",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "targets": [
        {
          "alias": "{{host.keyword}}",
          "bucketAggs": [
            {
              "field": "host.keyword",
              "id": "3",
              "settings": {
                "min_doc_count": "1",
                "order": "desc",
                "orderBy": "_count",
                "size": "10"
              },
              "type": "terms"
            },
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "*",
          "refId": "A",
