{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "📊 Log Volume Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Total log volume over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "alias": "Log Count",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "*",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Log Volume Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Total log events in selected time range",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Total Logs",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "*",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Total Log Events",
      "type": "stat"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Total error events in selected time range",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 9 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Error Count",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "level:error OR level:ERROR OR severity:error",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Total Error Events",
      "type": "stat"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Total warning events in selected time range",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 9 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Warning Count",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "level:warn OR level:WARN OR level:warning OR severity:warning",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Total Warning Events",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 6,
      "title": "🔴 Errors by Service",
      "type": "row"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Error count per service host over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "targets": [
        {
          "alias": "{{host.keyword}}",
          "bucketAggs": [
            {
              "field": "host.keyword",
              "id": "3",
              "settings": {
                "min_doc_count": "1",
                "order": "desc",
                "orderBy": "_count",
                "size": "10"
              },
              "type": "terms"
            },
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "auto" },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "level:error OR level:ERROR OR severity:error OR _exists_:error_classification",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Error Count by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 8,
      "title": "💬 Top Error Messages",
      "type": "row"
    },
    {
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "description": "Most frequent error messages",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 9,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "targets": [
        {
          "alias": "",
          "bucketAggs": [
            {
              "field": "message.keyword",
              "id": "3",
              "settings": {
                "min_doc_count": "1",
                "order": "desc",
                "orderBy": "_count",
                "size": "20"
              },
              "type": "terms"
            }
          ],
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "query": "level:error OR level:ERROR OR severity:error OR _exists_:error_classification",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Top Error Messages",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 10,
      "title": "📈 Log Level Distribution",
