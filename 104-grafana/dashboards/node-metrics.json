{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "⚡ CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Overall CPU utilization of the PVE host",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"192.168.50.100.*\"}[5m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "title": "PVE CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-core CPU usage over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 - (avg by (cpu)(rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"192.168.50.100.*\"}[5m])) * 100)",
          "legendFormat": "CPU {{cpu}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage by Core",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "🧠 Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "PVE host memory utilization",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=~\"192.168.50.100.*\"} / node_memory_MemTotal_bytes{instance=~\"192.168.50.100.*\"}) * 100",
          "legendFormat": "Memory Usage",
          "refId": "A"
        }
      ],
      "title": "PVE Memory Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory usage breakdown over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 10 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=~\"192.168.50.100.*\"} - node_memory_MemAvailable_bytes{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_Buffers_bytes{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Buffers",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Cached",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemFree_bytes{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Free",
          "refId": "D"
        }
      ],
      "title": "Memory Breakdown",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "💾 Disk I/O",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Disk read/write throughput",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=~\"192.168.50.100.*\", device!~\"dm-.*\"}[5m])",
          "legendFormat": "{{device}} read",
          "refId": "A"
        },
        {
          "expr": "-rate(node_disk_written_bytes_total{instance=~\"192.168.50.100.*\", device!~\"dm-.*\"}[5m])",
          "legendFormat": "{{device}} write",
          "refId": "B"
        }
      ],
      "title": "Disk Throughput (Read/Write)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Disk IOPS by device",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "iops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total{instance=~\"192.168.50.100.*\", device!~\"dm-.*\"}[5m])",
          "legendFormat": "{{device}} reads",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_writes_completed_total{instance=~\"192.168.50.100.*\", device!~\"dm-.*\"}[5m])",
          "legendFormat": "{{device}} writes",
          "refId": "B"
        }
      ],
      "title": "Disk IOPS",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "title": "🌐 Network",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Network interface throughput",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "TX(-) / RX(+)",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~\"192.168.50.100.*\", device!~\"lo|veth.*|docker.*|br.*\"}[5m])",
          "legendFormat": "{{device}} RX",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{instance=~\"192.168.50.100.*\", device!~\"lo|veth.*|docker.*|br.*\"}[5m])",
          "legendFormat": "{{device}} TX",
          "refId": "B"
        }
      ],
      "title": "Network Throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 12,
      "title": "📊 System Load",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "System load averages (1m, 5m, 15m)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "node_load1{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Load 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Load 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Load 15m",
          "refId": "C"
        }
      ],
      "title": "System Load Average",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "PVE host uptime",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "dtdurations"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 37 },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"192.168.50.100.*\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "title": "PVE Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Root filesystem usage",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 41 },
      "id": 15,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{instance=~\"192.168.50.100.*\", mountpoint=\"/\", fstype!=\"\"} / node_filesystem_size_bytes{instance=~\"192.168.50.100.*\", mountpoint=\"/\", fstype!=\"\"}) * 100)",
          "legendFormat": "Root Disk",
          "refId": "A"
        }
      ],
      "title": "Root Disk Usage",
      "type": "gauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["homelab", "node", "pve", "hardware", "node-exporter"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Node Metrics — PVE Host",
  "uid": "node-metrics"
}
