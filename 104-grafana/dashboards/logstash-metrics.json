{
  "uid": "logstash-metrics",
  "title": "Logstash Metrics",
  "description": "Logstash pipeline metrics from Prometheus exporter (port 9198)",
  "tags": ["elk", "logstash", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Events In (rate/s)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(logstash_events_in_total{job=\"logstash\"}[5m])",
          "legendFormat": "Events In",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Events Out (rate/s)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(logstash_events_out_total{job=\"logstash\"}[5m])",
          "legendFormat": "Events Out",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Events Filtered (rate/s)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(logstash_events_filtered_total{job=\"logstash\"}[5m])",
          "legendFormat": "Filtered",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Event Processing Duration",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(logstash_events_duration_in_millis_total{job=\"logstash\"}[5m]) / (rate(logstash_events_out_total{job=\"logstash\"}[5m]) > 0)",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Events Total (cumulative)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "logstash_events_in_total{job=\"logstash\"}",
          "legendFormat": "Total In",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Scrape Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "up{job=\"logstash\"}",
          "legendFormat": "Logstash",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Event Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Events In/Out Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "spanNulls": false,
            "drawStyle": "line",
            "showPoints": "auto",
            "stacking": { "mode": "none" },
            "axisLabel": "events/sec"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(logstash_events_in_total{job=\"logstash\"}[5m])",
          "legendFormat": "Events In",
          "refId": "A"
        },
        {
          "expr": "rate(logstash_events_out_total{job=\"logstash\"}[5m])",
          "legendFormat": "Events Out",
          "refId": "B"
        },
        {
          "expr": "rate(logstash_events_filtered_total{job=\"logstash\"}[5m])",
          "legendFormat": "Events Filtered",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Event Processing Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "showPoints": "auto",
            "stacking": { "mode": "none" },
            "axisLabel": "ms"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(logstash_events_duration_in_millis_total{job=\"logstash\"}[5m]) / (rate(logstash_events_out_total{job=\"logstash\"}[5m]) > 0)",
          "legendFormat": "Avg Processing Time",
          "refId": "A"
        },
        {
          "expr": "rate(logstash_events_queue_push_duration_in_millis_total{job=\"logstash\"}[5m]) / (rate(logstash_events_in_total{job=\"logstash\"}[5m]) > 0)",
          "legendFormat": "Avg Queue Push Time",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "title": "Pipeline Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Event Drop Rate (In - Out)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line",
            "showPoints": "auto",
            "stacking": { "mode": "none" },
            "axisLabel": "events/sec",
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(logstash_events_in_total{job=\"logstash\"}[5m]) - rate(logstash_events_out_total{job=\"logstash\"}[5m])",
          "legendFormat": "Drop Rate (In - Out)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Cumulative Events",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "logstash_events_in_total{job=\"logstash\"}",
          "legendFormat": "Total In",
          "refId": "A"
        },
        {
          "expr": "logstash_events_out_total{job=\"logstash\"}",
          "legendFormat": "Total Out",
          "refId": "B"
        },
        {
          "expr": "logstash_events_filtered_total{job=\"logstash\"}",
          "legendFormat": "Total Filtered",
          "refId": "C"
        }
      ]
    }
  ],
  "__inputs": [],
  "__requires": []
}
